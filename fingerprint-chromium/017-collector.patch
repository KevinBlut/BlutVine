+}
+
+void FlushAudioIfNew(const uint8_t* bytes, size_t byte_len, double render_ms) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    if (g_input_log.empty()) return;
+
+    std::string dir = GetAudioDir();
+    if (dir.empty()) return;
+
+    uint64_t h = HashInputLog();
+    g_input_log.clear();
+
+    char hash_hex[17];
+    snprintf(hash_hex, sizeof(hash_hex), "%016llx", (unsigned long long)h);
+
+    base::CreateDirectory(base::FilePath(dir));
+
+    std::string json_path = dir + hash_hex + "_audio.json";
+    std::string bin_path  = dir + hash_hex + "_audio.bin";
+
+    if (base::PathExists(base::FilePath(json_path)))
+        return;
+
+    std::ostringstream ss;
+    ss << "{\n"
+       << "  \"site\": \""    << EscapeJson(g_current_site) << "\",\n"
+       << "  \"trigger\": \"audio\",\n"
+       << "  \"hash\": \""    << hash_hex << "\",\n"
+       << "  \"render_ms\": " << render_ms << "\n"
+       << "}";
+    {
+        std::ofstream f(json_path);
+        if (f.is_open()) f << ss.str();
+    }
+
+    if (bytes && byte_len > 0) {
+        std::ofstream f(bin_path, std::ios::binary);
+        if (f.is_open())
+            f.write(reinterpret_cast<const char*>(bytes), byte_len);
+    }
+}
+
+static thread_local std::unordered_map<uint64_t, ReplayEntry> g_audio_replay_map;
+static thread_local std::string g_audio_replay_loaded_site;
+
+static void AudioReplayLoad() {
+    g_audio_replay_map.clear();
+    g_audio_replay_loaded_site = g_current_site;
+
+    std::string dir = GetAudioDir();
+    if (dir.empty()) return;
+
+    base::FilePath dir_path(dir);
+    base::FileEnumerator enumerator(dir_path, false,
+                                    base::FileEnumerator::FILES,
+                                    FILE_PATH_LITERAL("*.json"));
+    for (base::FilePath json_path = enumerator.Next();
+         !json_path.empty();
+         json_path = enumerator.Next()) {
+        std::string contents;
+        if (!base::ReadFileToString(json_path, &contents)) continue;
+
+        std::string hash_str = JsonGetString(contents, "hash");
+        if (hash_str.empty()) continue;
+
+        uint64_t hash = std::stoull(hash_str, nullptr, 16);
+        std::string bin_path =
+            json_path.RemoveFinalExtension().value() + ".bin";
+
+        ReplayEntry entry;
+        entry.bin_path  = bin_path;
+        entry.width     = 0;
+        entry.height    = 0;
+        entry.trigger   = "audio";
+        entry.render_ms = JsonGetDouble(contents, "render_ms");
+        g_audio_replay_map[hash] = std::move(entry);
+    }
+}
+
+std::vector<uint8_t> ReplayAudioOutput() {
+    if (g_audio_replay_loaded_site != g_current_site)
+        AudioReplayLoad();
+
+    uint64_t hash = HashInputLog();
+    g_input_log.clear();
+
+    auto it = g_audio_replay_map.find(hash);
+    if (it == g_audio_replay_map.end()) {
+        fprintf(stderr, "[FP-REPLAY MISS] site=%s trigger=audio\n",
+                g_current_site.c_str());
+        return {};
+    }
+
+    const ReplayEntry& entry = it->second;
+    auto t0 = base::TimeTicks::Now();
+
+    std::ifstream f(entry.bin_path, std::ios::binary);
+    if (!f.is_open()) {
+        fprintf(stderr,
+                "[FP-REPLAY MISS] site=%s trigger=audio (bin missing: %s)\n",
+                g_current_site.c_str(), entry.bin_path.c_str());
+        return {};
+    }
+
+    std::vector<uint8_t> result{
+        std::istreambuf_iterator<char>(f),
+        std::istreambuf_iterator<char>()};
+
+    double elapsed_ms = (base::TimeTicks::Now() - t0).InMillisecondsF();
+
+    if (entry.render_ms > 0.0) {
+        double jitter_factor = 1.0 + (static_cast<int>(
+            base::RandGenerator(41)) - 20)) / 1000.0);
+        double target_ms = entry.render_ms * jitter_factor;
+        double delta_ms = target_ms - elapsed_ms;
+        if (delta_ms > 1.0) {
+            base::PlatformThread::Sleep(
+                base::Milliseconds(static_cast<int64_t>(delta_ms)));
+        }
+    }
+
+    return result;
+}
