 static uint64_t FNV64(uint64_t hash, const void* data, size_t len) {
     const uint8_t* p = static_cast<const uint8_t*>(data);
     for (size_t i = 0; i < len; i++) {
         hash ^= p[i];
         hash *= 0x00000100000001B3ULL;
     }
     return hash;
 }
 
 static uint64_t HashInputLog() {
     uint64_t h = 0xcbf29ce484222325ULL;
     for (const auto& e : g_input_log) {
         h = FNV64(h, e.op.data(), e.op.size());
         h = FNV64(h, e.text.data(), e.text.size());
         h = FNV64(h, e.font.data(), e.font.size());
         h = FNV64(h, &e.x, sizeof(e.x));
         h = FNV64(h, &e.y, sizeof(e.y));
         h = FNV64(h, &e.text_align, sizeof(e.text_align));
         h = FNV64(h, &e.text_baseline, sizeof(e.text_baseline));
         h = FNV64(h, &e.max_width, sizeof(e.max_width));
         h = FNV64(h, &e.rect_width, sizeof(e.rect_width));
         h = FNV64(h, &e.rect_height, sizeof(e.rect_height));
     }
     return h;
 }
 
