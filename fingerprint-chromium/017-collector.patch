+// ---------------------------------------------------------------------------
+// Audio Collect + Replay
+// ---------------------------------------------------------------------------
+
+void FlushAudioIfNew(const uint8_t* bytes, size_t byte_len,
+                     double render_ms) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    if (g_input_log.empty()) return;
+    base::ScopedAllowBlocking allow_blocking;
+    std::string dir = GetCollectDir("audio");
+    if (dir.empty()) return;
+
+    uint64_t h = HashInputLog();
+    g_input_log.clear();
+    std::string hash_hex = HashHex(h);
+
+    base::CreateDirectory(base::FilePath(dir));
+
+    std::string json_path = dir + hash_hex + "_audio.json";
+    if (base::PathExists(base::FilePath(json_path)))
+        return;
+
+    std::ostringstream ss;
+    ss << "{\n"
+       << "  \"site\": \""    << EscapeJson(g_current_site) << "\",\n"
+       << "  \"trigger\": \"audio\",\n"
+       << "  \"hash\": \""    << hash_hex << "\",\n"
+       << "  \"render_ms\": " << render_ms << ",\n"
+       << "  \"data\": \""
+       << (bytes && byte_len > 0 ? Base64Encode(bytes, byte_len) : "")
+       << "\"\n"
+       << "}";
+    std::ofstream f(json_path);
+    if (f.is_open()) f << ss.str();
+}
+
+std::vector<uint8_t> ReplayAudioOutput() {
+    return ReplayLookup("audio", "audio").bytes;
+}
+
+// ---------------------------------------------------------------------------
+// measureText Collect + Replay
+// ---------------------------------------------------------------------------
+
+void FlushMeasureTextIfNew(const double* values, size_t count) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    if (g_input_log.empty()) return;
+    base::ScopedAllowBlocking allow_blocking;
+    std::string dir = GetCollectDir("measuretext");
+    if (dir.empty()) return;
+
+    uint64_t h = HashInputLog();
+    g_input_log.clear();
+    std::string hash_hex = HashHex(h);
+
+    base::CreateDirectory(base::FilePath(dir));
+
+    std::string json_path = dir + hash_hex + "_measureText.json";
+    if (base::PathExists(base::FilePath(json_path)))
+        return;
+
+    std::string b64;
+    if (values && count > 0) {
+        b64 = Base64Encode(
+            reinterpret_cast<const uint8_t*>(values),
+            count * sizeof(double));
+    }
+
+    std::ostringstream ss;
+    ss << "{\n"
+       << "  \"site\": \""    << EscapeJson(g_current_site) << "\",\n"
+       << "  \"trigger\": \"measureText\",\n"
+       << "  \"hash\": \""    << hash_hex << "\",\n"
+       << "  \"data\": \""    << b64 << "\"\n"
+       << "}";
+    std::ofstream f(json_path);
+    if (f.is_open()) f << ss.str();
+}
+
+std::vector<double> ReplayMeasureText() {
+    ReplayResult r = ReplayLookup("measureText", "measuretext");
+    if (r.bytes.empty() || r.bytes.size() < 9 * sizeof(double))
+        return {};
+    std::vector<double> result(r.bytes.size() / sizeof(double));
+    memcpy(result.data(), r.bytes.data(), result.size() * sizeof(double));
+    return result;
+}
