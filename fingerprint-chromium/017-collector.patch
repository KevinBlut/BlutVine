+// ---------------------------------------------------------------------------
+// Profile replay cache
+// ---------------------------------------------------------------------------
+// Cache file: <user-data-dir>/fp_replay_cache.json
+// Format: flat JSON object { "<test_hash>": "<result_filename>", ... }
+//
+// On first encounter of a test hash the available result_*.json files are
+// enumerated, one is chosen at random, and the choice is persisted so the
+// same profile always replays the same result for that test.
+
+static std::string GetCachePath() {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    std::string udd = cmd->GetSwitchValueASCII("user-data-dir");
+    if (udd.empty()) return "";
+    return udd + "/fp_replay_cache.json";
+}
+
+// Minimal JSON object reader: returns value for key in a flat {"k":"v",...}.
+static std::string CacheGet(const std::string& json,
+                             const std::string& key) {
+    std::string needle = "\"" + key + "\":\"";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return "";
+    pos += needle.size();
+    size_t end = json.find('"', pos);
+    if (end == std::string::npos) return "";
+    return json.substr(pos, end - pos);
+}
+
+// Load the cache JSON; returns empty string if missing or unreadable.
+static std::string LoadCache() {
+    std::string path = GetCachePath();
+    if (path.empty()) return "{}";
+    base::ScopedAllowBlocking allow_blocking;
+    std::string contents;
+    if (!base::ReadFileToString(base::FilePath(path), &contents))
+        return "{}";
+    return contents;
+}
+
+// Write a single key-value pair into the cache file.
+// Re-reads the file so concurrent profiles don't clobber each other's keys.
+static void CacheSet(const std::string& key, const std::string& value) {
+    std::string path = GetCachePath();
+    if (path.empty()) return;
+    base::ScopedAllowBlocking allow_blocking;
+
+    std::string existing;
+    base::ReadFileToString(base::FilePath(path), &existing);
+    if (existing.empty() || existing == "{}") {
+        existing = "{}";
+    }
+
+    // Insert before closing brace.
+    // Simple approach: strip trailing "}" and append.
+    size_t end = existing.rfind('}');
+    if (end == std::string::npos) {
+        existing = "{}";
+        end = 1;
+    }
+
+    std::string entry = "\"" + EscapeJson(key) + "\":\"" +
+                        EscapeJson(value) + "\"";
+
+    std::string updated;
+    if (end == 1) {
+        // Empty object
+        updated = "{" + entry + "}";
+    } else {
+        updated = existing.substr(0, end) + "," + entry + "}";
+    }
+
+    std::ofstream f(path);
+    if (f.is_open()) f << updated;
+}
+
+// Choose (or recall) a result filename for this test hash + replay dir.
+// Returns empty string if no results exist.
+static std::string PickResult(const std::string& test_hash_hex,
+                               const std::string& dir) {
+    // Check cache first.
+    std::string cache = LoadCache();
+    std::string cached = CacheGet(cache, test_hash_hex);
+    if (!cached.empty()) {
+        // Verify the cached file still exists.
+        if (base::PathExists(base::FilePath(dir + cached)))
+            return cached;
+        // Cached file missing — fall through to re-pick.
+    }
+
+    // Enumerate result_*.json files in dir.
+    base::ScopedAllowBlocking allow_blocking;
+    base::FilePath dir_path(dir);
+    std::vector<std::string> candidates;
+    base::FileEnumerator enumerator(dir_path, false,
+                                    base::FileEnumerator::FILES,
+                                    FILE_PATH_LITERAL("result_*.json"));
+    for (base::FilePath p = enumerator.Next();
+         !p.empty();
+         p = enumerator.Next()) {
+        candidates.push_back(p.BaseName().value());
+    }
+
+    if (candidates.empty()) return "";
+
+    // Random pick — seeded from profile ID for determinism within a process,
+    // but varies across profiles.
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    std::string profile_id =
+        cmd->GetSwitchValueASCII(switches::kFingerprintReplay);
+    std::size_t seed = std::hash<std::string>{}(profile_id + test_hash_hex);
+    std::mt19937 rng(static_cast<uint32_t>(seed));
+    std::uniform_int_distribution<size_t> dist(0, candidates.size() - 1);
+    std::string chosen = candidates[dist(rng)];
+
+    // Persist choice so this profile always gets the same result.
+    CacheSet(test_hash_hex, chosen);
+    return chosen;
+}
+
+// ---------------------------------------------------------------------------
+// Unified replay lookup
+// ---------------------------------------------------------------------------
+// 1. Hash input log -> test_hash_hex
+// 2. Build hardware-keyed directory path
+// 3. Pick (or recall) a result_*.json from that directory
+// 4. Parse result.json: decode base64 "data", extract render_ms
+// 5. Apply ±2% jitter sleep
+// 6. Return decoded bytes
+
+struct ReplayResult {
+    std::vector<uint8_t> bytes;
+    std::string trigger;
+    int width  = 0;
+    int height = 0;
+    double render_ms = 0.0;
+};
+
+static ReplayResult ReplayLookup(const std::string& expected_trigger) {
+    uint64_t hash = HashInputLog();
+    g_input_log.clear();
+    std::string hash_hex = HashHex(hash);
+
+    std::string dir = BuildReplayDir(hash_hex);
+    if (dir.empty()) {
+        fprintf(stderr, "[FP-REPLAY MISS] no replay db configured\n");
+        return {};
+    }
+
+    base::ScopedAllowBlocking allow_blocking;
+
+    std::string filename = PickResult(hash_hex, dir);
+    if (filename.empty()) {
+        fprintf(stderr,
+                "[FP-REPLAY MISS] trigger=%s hash=%s (no results in %s)\n",
+                expected_trigger.c_str(), hash_hex.c_str(), dir.c_str());
+        return {};
+    }
+
+    std::string json_path = dir + filename;
+    std::string contents;
+    if (!base::ReadFileToString(base::FilePath(json_path), &contents)) {
+        fprintf(stderr,
+                "[FP-REPLAY MISS] trigger=%s hash=%s (unreadable: %s)\n",
+                expected_trigger.c_str(), hash_hex.c_str(),
+                json_path.c_str());
+        return {};
+    }
+
+    // Parse fields from result JSON.
+    ReplayResult result;
+    result.trigger   = JsonGetString(contents, "trigger");
+    result.width     = JsonGetInt(contents, "width");
+    result.height    = JsonGetInt(contents, "height");
+    result.render_ms = JsonGetDouble(contents, "render_ms");
+
+    std::string b64 = JsonGetString(contents, "data");
+    if (b64.empty()) {
+        fprintf(stderr,
+                "[FP-REPLAY MISS] trigger=%s hash=%s (no data field: %s)\n",
+                expected_trigger.c_str(), hash_hex.c_str(),
+                json_path.c_str());
+        return {};
+    }
+    result.bytes = Base64Decode(b64);
+
+    // ±2% jitter sleep to match stored render timing.
+    if (result.render_ms > 0.0) {
+        auto t0 = base::TimeTicks::Now();
+        double elapsed_ms = (base::TimeTicks::Now() - t0).InMillisecondsF();
+        double jitter_factor = 1.0 + (static_cast<int>(
+            base::RandGenerator(41)) - 20) / 1000.0;
+        double target_ms  = result.render_ms * jitter_factor;
+        double delta_ms   = target_ms - elapsed_ms;
+        if (delta_ms > 1.0) {
+            base::PlatformThread::Sleep(
+                base::Milliseconds(static_cast<int64_t>(delta_ms)));
+        }
+    }
+
+    return result;
+}
