+    base::CreateDirectory(base::FilePath(dir));
+
+    std::string json_path = dir + hash_hex + "_measureText.json";
+    std::string bin_path  = dir + hash_hex + "_measureText.bin";
+
+    if (base::PathExists(base::FilePath(json_path)))
