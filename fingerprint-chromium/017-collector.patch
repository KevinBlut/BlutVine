+static std::string BuildReplayDir(const std::string& test_hash_hex) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintReplayDatabase))
+        return "";
+
+    std::string replay_db =
+        cmd->GetSwitchValueASCII(switches::kFingerprintReplayDatabase);
+
+    // OS: derived from UA string via GetPlatformFromUA()
+    std::string os;
+    if (cmd->HasSwitch(switches::kFingerprintUA)) {
+        os = blink::GetPlatformFromUA(
+            cmd->GetSwitchValueASCII(switches::kFingerprintUA));
+    }
+    if (os.empty()) os = "unknown";
+
+    std::string chip_model =
+        cmd->HasSwitch(switches::kFingerprintCHUAModel)
+            ? SanitizeForPath(
+                  cmd->GetSwitchValueASCII(switches::kFingerprintCHUAModel))
+            : "unknown";
+
+    std::string os_version =
+        cmd->HasSwitch(switches::kFingerprintPlatformVersion)
+            ? SanitizeForPath(
+                  cmd->GetSwitchValueASCII(switches::kFingerprintPlatformVersion))
+            : "unknown";
+
+    // Driver name: sanitized GPU renderer string
+    // e.g. "NVIDIA GeForce RTX 4070/PCIe/SSE2" -> "NVIDIA_GeForce_RTX_4070_PCIe_SSE2"
+    std::string driver =
+        cmd->HasSwitch(switches::kFingerprintGpuRenderer)
+            ? SanitizeForPath(
+                  cmd->GetSwitchValueASCII(switches::kFingerprintGpuRenderer))
+            : "unknown";
+
+    std::string driver_version =
+        cmd->HasSwitch(switches::kFingerprintGpuDriver)
+            ? SanitizeForPath(
+                  cmd->GetSwitchValueASCII(switches::kFingerprintGpuDriver))
+            : "unknown";
+
+    std::string dpr =
+        cmd->HasSwitch(switches::kFingerprintScreenDevicePixelRatio)
+            ? SanitizeForPath(cmd->GetSwitchValueASCII(
+                  switches::kFingerprintScreenDevicePixelRatio))
+            : "unknown";
+
+    return replay_db + "/" +
+           test_hash_hex + "/" +
+           chip_model + "/" +
+           os + "/" +
+           os_version + "/" +
+           driver + "/" +
+           driver_version + "/" +
+           dpr + "/";
+}
