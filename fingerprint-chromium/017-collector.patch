+// ---------------------------------------------------------------------------
+// Site management
+// ---------------------------------------------------------------------------
+
+void SetCurrentSite(const std::string& url) {
+    GURL gurl(url);
+    if (gurl.is_valid())
+        g_current_site = gurl.DeprecatedGetOriginAsURL().spec();
+    else
+        g_current_site = url;
+}
+
+void ClearInputLog() {
+    g_input_log.clear();
+}
