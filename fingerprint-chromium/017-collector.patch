+#pragma once
+
+#include <string>
+#include <cstdint>
+#include <vector>
+#include "base/component_export.h"
+
+namespace fingerprint_collector {
+
+// ---------------------------------------------------------------------------
+// Collect — input logging
+// ---------------------------------------------------------------------------
+
+// Log a canvas drawing command into the thread-local input log.
+// Called for fillText, strokeText, measureText, etc.
+COMPONENT_EXPORT(UNGOOGLED) void LogCanvasInput(
+    const std::string& op,
+    const std::string& text,
+    double x, double y,
+    const std::string& font,
+    int text_align,
+    int text_baseline,
+    double max_width = -1.0
+);
+
+// Log a rect drawing command (fillRect, drawImage).
+COMPONENT_EXPORT(UNGOOGLED) void LogRectInput(
+    double x, double y,
+    double width, double height
+);
+
+// Log audio context parameters as the test identity.
+// Must be called before FlushAudioIfNew or ReplayAudioOutput so that
+// HashInputLog() produces a key that distinguishes different audio tests.
+// channels    — numberOfChannels (OfflineAudioContext) or 1 (AnalyserNode)
+// length      — numberOfFrames (OfflineAudioContext) or fftSize/2 or fftSize
+// sample_rate — sampleRate, or 0.0 when not available (AnalyserNode paths)
+COMPONENT_EXPORT(UNGOOGLED) void LogAudioInput(
+    int channels, int length, float sample_rate
+);
+
+// Hash the current input log, write recipe JSON if new, clear log.
+// render_ms — GPU/CPU readback time measured by the caller (0.0 if unknown).
+// category  — "canvas" for 2D canvas surfaces, "webgl" for WebGL readbacks.
+COMPONENT_EXPORT(UNGOOGLED) void FlushTestIfNew(
+    const std::string& trigger,
+    double render_ms,
+    const std::string& category
+);
+
+// ---------------------------------------------------------------------------
+// Site management
+// ---------------------------------------------------------------------------
+
+// Set the current site — normalizes to origin (scheme+host+port).
+// Must be called before any Log* or Flush* call for a given page.
+// Only relevant for collect — replay uses hardware switches directly.
+COMPONENT_EXPORT(UNGOOGLED) void SetCurrentSite(const std::string& url);
+
+// Clear the thread-local input log — call at page navigation.
+COMPONENT_EXPORT(UNGOOGLED) void ClearInputLog();
+
+// ---------------------------------------------------------------------------
+// Canvas / WebGL Replay
+// ---------------------------------------------------------------------------
+
+// Returns stored pixel bytes or empty on miss.
+// Caller falls through to real GPU output if empty.
+// Internally applies ±2% jitter sleep based on stored render_ms.
+COMPONENT_EXPORT(UNGOOGLED) std::vector<uint8_t> ReplayCanvasOutput(
+    const std::string& trigger
+);
+
+// WebGL readPixels / getBufferSubData replay.
+COMPONENT_EXPORT(UNGOOGLED) std::vector<uint8_t> ReplayWebGLOutput();
+
+// WebGL transferToImageBitmap replay — same "webgl" category as readPixels
+// but different trigger so corpus entries are distinct.
+COMPONENT_EXPORT(UNGOOGLED) std::vector<uint8_t> ReplayWebGLTransfer();
+
+// ---------------------------------------------------------------------------
+// Audio Collect + Replay
+// ---------------------------------------------------------------------------
+
+// Flush recipe JSON + base64-encoded audio data into the collect DB.
+// bytes     — raw float32 LE buffer (all channels concatenated)
+// byte_len  — size in bytes
+// render_ms — time to extract the audio buffer, for replay jitter
+COMPONENT_EXPORT(UNGOOGLED) void FlushAudioIfNew(
+    const uint8_t* bytes,
+    size_t byte_len,
+    double render_ms
+);
+
+// Load audio result from hardware-keyed replay path.
+// Returns empty vector on miss.
+// Internally applies ±2% jitter sleep based on stored render_ms.
+COMPONENT_EXPORT(UNGOOGLED) std::vector<uint8_t> ReplayAudioOutput();
+
+// ---------------------------------------------------------------------------
+// measureText Collect + Replay
+// ---------------------------------------------------------------------------
+
+// Flush recipe JSON + base64-encoded 9 doubles into the collect DB.
+// values[0..8]: width, bbox_left, bbox_right, font_ascent, font_descent,
+//               actual_ascent, actual_descent, em_ascent, em_descent
+COMPONENT_EXPORT(UNGOOGLED) void FlushMeasureTextIfNew(
+    const double* values,
+    size_t count
+);
+
+// Returns 9 doubles or empty on miss.
+COMPONENT_EXPORT(UNGOOGLED) std::vector<double> ReplayMeasureText();
+
+// ---------------------------------------------------------------------------
+// clientRects Collect + Replay
+// ---------------------------------------------------------------------------
+
+// Flush recipe JSON + base64-encoded float x/y offset pairs into collect DB.
+// values  — array of x/y offset pairs per rect
+// count   — total number of floats (rect_count * 2)
+// trigger — "getClientRects", "getBoundingClientRect",
+//           "range.getClientRects", "range.getBoundingClientRect"
+COMPONENT_EXPORT(UNGOOGLED) void FlushClientRectsIfNew(
+    const float* values,
+    size_t count,
+    const std::string& trigger
+);
+
+// Returns float x/y offset pairs or empty on miss.
+COMPONENT_EXPORT(UNGOOGLED) std::vector<float> ReplayClientRects(
+    const std::string& trigger
+);
+
+}  // namespace fingerprint_collector
