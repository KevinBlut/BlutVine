+    base::FilePath dir_path(dir);
+    base::FileEnumerator enumerator(dir_path, false,
+                                    base::FileEnumerator::FILES,
+                                    FILE_PATH_LITERAL("*.json"));
+    for (base::FilePath json_path = enumerator.Next();
+         !json_path.empty();
+         json_path = enumerator.Next()) {
+        std::string contents;
+        if (!base::ReadFileToString(json_path, &contents)) continue;
+
+        std::string hash_str = JsonGetString(contents, "hash");
+        if (hash_str.empty()) continue;
+
+        uint64_t hash = std::stoull(hash_str, nullptr, 16);
+        std::string bin_path =
+            json_path.RemoveFinalExtension().value() + ".bin";
+
+        ReplayEntry entry;
+        entry.bin_path  = bin_path;
+        entry.width     = 0;
+        entry.height    = 0;
+        entry.trigger   = "measureText";
+        entry.render_ms = 0.0;
+        g_measuretext_replay_map[hash] = std::move(entry);
+    }
+}
+
+std::vector<double> ReplayMeasureText() {
+    if (g_measuretext_replay_loaded_site != g_current_site)
+        MeasureTextReplayLoad();
+
+    uint64_t hash = HashInputLog();
+    g_input_log.clear();
+
+    auto it = g_measuretext_replay_map.find(hash);
+    if (it == g_measuretext_replay_map.end()) {
+        fprintf(stderr, "[FP-REPLAY MISS] site=%s trigger=measureText\n",
+                g_current_site.c_str());
+        return {};
+    }
+
+    const ReplayEntry& entry = it->second;
+    std::ifstream f(entry.bin_path, std::ios::binary);
+    if (!f.is_open()) {
+        fprintf(stderr,
+                "[FP-REPLAY MISS] site=%s trigger=measureText (bin: %s)\n",
+                g_current_site.c_str(), entry.bin_path.c_str());
+        return {};
+    }
+
+    std::vector<uint8_t> raw{
+        std::istreambuf_iterator<char>(f),
+        std::istreambuf_iterator<char>()};
+
+    if (raw.size() < 9 * sizeof(double)) return {};
+
+    std::vector<double> result(raw.size() / sizeof(double));
+    memcpy(result.data(), raw.data(), result.size() * sizeof(double));
+    return result;
+}
+
+// ---------------------------------------------------------------------------
+// clientRects Collect + Replay
+// ---------------------------------------------------------------------------
+
+static std::string GetClientRectsDir() {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintDatabase))
+        return "";
+
+    std::string db_path = cmd->GetSwitchValueASCII(switches::kFingerprintDatabase);
+
+    std::string os_version = "unknown_os";
+    if (cmd->HasSwitch(switches::kFingerprintPlatformVersion))
+        os_version = cmd->GetSwitchValueASCII(switches::kFingerprintPlatformVersion);
+    std::transform(os_version.begin(), os_version.end(), os_version.begin(), ::tolower);
+    std::replace(os_version.begin(), os_version.end(), ' ', '_');
+
+    std::string dpr = "1_0";
+    if (cmd->HasSwitch(switches::kFingerprintScreenDevicePixelRatio)) {
+        dpr = cmd->GetSwitchValueASCII(switches::kFingerprintScreenDevicePixelRatio);
+        std::replace(dpr.begin(), dpr.end(), '.', '_');
+    }
+
+    std::string site = g_current_site.empty() ? "unknown" : SanitizeForPath(g_current_site);
+
+    return db_path + "/" + site + "/";
+}
+
+void FlushClientRectsIfNew(const float* values, size_t count,
+                           const std::string& trigger) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    if (g_input_log.empty()) return;
+
+    std::string dir = GetClientRectsDir();
+    if (dir.empty()) return;
+
+    uint64_t h = HashInputLog();
+    g_input_log.clear();
+
+    char hash_hex[17];
+    snprintf(hash_hex, sizeof(hash_hex), "%016llx", (unsigned long long)h);
+
+    base::CreateDirectory(base::FilePath(dir));
+
+    std::string json_path = dir + hash_hex + "_" + trigger + ".json";
+    std::string bin_path  = dir + hash_hex + "_" + trigger + ".bin";
+
+    if (base::PathExists(base::FilePath(json_path)))
+        return;
+
+    std::ostringstream ss;
+    ss << "{\n"
+       << "  \"site\": \""    << EscapeJson(g_current_site) << "\",\n"
+       << "  \"trigger\": \"" << trigger << "\",\n"
+       << "  \"hash\": \""    << hash_hex << "\"\n"
+       << "}";
+    {
+        std::ofstream f(json_path);
+        if (f.is_open()) f << ss.str();
+    }
+
+    if (values && count > 0) {
+        std::ofstream f(bin_path, std::ios::binary);
+        if (f.is_open())
+            f.write(reinterpret_cast<const char*>(values),
+                    count * sizeof(float));
+    }
+}
+
+static thread_local std::unordered_map<uint64_t, ReplayEntry> g_clientrects_replay_map;
+static thread_local std::string g_clientrects_replay_loaded_site;
+
+static void ClientRectsReplayLoad() {
+    g_clientrects_replay_map.clear();
+    g_clientrects_replay_loaded_site = g_current_site;
+
+    std::string dir = GetClientRectsDir();
+    if (dir.empty()) return;
+
+    base::FilePath dir_path(dir);
+    base::FileEnumerator enumerator(dir_path, false,
+                                    base::FileEnumerator::FILES,
+                                    FILE_PATH_LITERAL("*.json"));
+    for (base::FilePath json_path = enumerator.Next();
+         !json_path.empty();
+         json_path = enumerator.Next()) {
+        std::string contents;
+        if (!base::ReadFileToString(json_path, &contents)) continue;
+
+        std::string hash_str = JsonGetString(contents, "hash");
+        if (hash_str.empty()) continue;
+
+        uint64_t hash = std::stoull(hash_str, nullptr, 16);
+        std::string bin_path =
+            json_path.RemoveFinalExtension().value() + ".bin";
+
+        ReplayEntry entry;
+        entry.bin_path  = bin_path;
+        entry.width     = 0;
+        entry.height    = 0;
+        entry.trigger   = JsonGetString(contents, "trigger");
+        entry.render_ms = 0.0;
+        g_clientrects_replay_map[hash] = std::move(entry);
+    }
+}
+
+std::vector<float> ReplayClientRects(const std::string& trigger) {
+    if (g_clientrects_replay_loaded_site != g_current_site)
+        ClientRectsReplayLoad();
+
+    uint64_t hash = HashInputLog();
+    g_input_log.clear();
+
+    auto it = g_clientrects_replay_map.find(hash);
+    if (it == g_clientrects_replay_map.end()) {
+        fprintf(stderr, "[FP-REPLAY MISS] site=%s trigger=%s\n",
+                g_current_site.c_str(), trigger.c_str());
+        return {};
+    }
+
+    const ReplayEntry& entry = it->second;
+    std::ifstream f(entry.bin_path, std::ios::binary);
+    if (!f.is_open()) {
+        fprintf(stderr,
+                "[FP-REPLAY MISS] site=%s trigger=%s (bin: %s)\n",
+                g_current_site.c_str(), trigger.c_str(),
+                entry.bin_path.c_str());
+        return {};
+    }
+
+    std::vector<uint8_t> raw{
+        std::istreambuf_iterator<char>(f),
+        std::istreambuf_iterator<char>()};
+
+    if (raw.size() < sizeof(float)) return {};
+
+    std::vector<float> result(raw.size() / sizeof(float));
+    memcpy(result.data(), raw.data(), result.size() * sizeof(float));
+    return result;
+}
+
+}  // namespace fingerprint_collector
