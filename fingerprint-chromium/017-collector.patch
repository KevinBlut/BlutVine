+// ---------------------------------------------------------------------------
+// Input log
+// ---------------------------------------------------------------------------
+
+struct InputEntry {
+    std::string op;
+    std::string text;
+    double x, y;
+    std::string font;
+    int text_align;
+    int text_baseline;
+    double max_width;
+    double rect_width, rect_height;
+};
+
+static thread_local std::vector<InputEntry> g_input_log;
+static thread_local std::string g_current_site;
+
+// ---------------------------------------------------------------------------
+// Helpers
+// ---------------------------------------------------------------------------
+
+static std::string SanitizeForPath(const std::string& s) {
+    std::string out;
+    for (unsigned char c : s) {
+        if (c == '/' || c == '\\' || c == ':' || c == '*' ||
+            c == '?' || c == '"' || c == '<' || c == '>' || c == '|')
+            out += '_';
+        else
+            out += c;
+    }
+    return out;
+}
+
+static std::string EscapeJson(const std::string& s) {
+    std::string out;
+    for (unsigned char c : s) {
+        if (c == '"')       out += "\\\"";
+        else if (c == '\\') out += "\\\\";
+        else if (c == '\n') out += "\\n";
+        else if (c == '\r') out += "\\r";
+        else if (c == '\t') out += "\\t";
+        else if (c < 0x20)  { /* skip control chars */ }
+        else out += c;
+    }
+    return out;
+}
+
+static uint64_t FNV64(uint64_t hash, const void* data, size_t len) {
+    const uint8_t* p = static_cast<const uint8_t*>(data);
+    for (size_t i = 0; i < len; i++) {
+        hash ^= p[i];
+        hash *= 0x00000100000001B3ULL;
+    }
+    return hash;
+}
+
+static uint64_t HashInputLog() {
+    uint64_t h = 0xcbf29ce484222325ULL;
+    for (const auto& e : g_input_log) {
+        h = FNV64(h, e.op.data(), e.op.size());
+        h = FNV64(h, e.text.data(), e.text.size());
+        h = FNV64(h, e.font.data(), e.font.size());
+        h = FNV64(h, &e.x, sizeof(e.x));
+        h = FNV64(h, &e.y, sizeof(e.y));
+        h = FNV64(h, &e.text_align, sizeof(e.text_align));
+        h = FNV64(h, &e.text_baseline, sizeof(e.text_baseline));
+        h = FNV64(h, &e.max_width, sizeof(e.max_width));
+        h = FNV64(h, &e.rect_width, sizeof(e.rect_width));
+        h = FNV64(h, &e.rect_height, sizeof(e.rect_height));
+    }
+    return h;
+}
+
+static std::string GetOutputDir() {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintDatabase))
+        return "";
+    std::string db_path = cmd->GetSwitchValueASCII(switches::kFingerprintDatabase);
+    std::string site = g_current_site.empty() ? "unknown" : SanitizeForPath(g_current_site);
+    return db_path + "/" + site + "/";
+}
+
+static std::string JsonGetString(const std::string& json, const std::string& key) {
+    std::string needle = "\"" + key + "\":\"";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return "";
+    pos += needle.size();
+    size_t end = json.find('"', pos);
+    if (end == std::string::npos) return "";
+    return json.substr(pos, end - pos);
+}
+
+static int JsonGetInt(const std::string& json, const std::string& key) {
+    std::string needle = "\"" + key + "\":";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return 0;
+    pos += needle.size();
+    return std::stoi(json.substr(pos));
+}
+
+static double JsonGetDouble(const std::string& json, const std::string& key) {
+    std::string needle = "\"" + key + "\":";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return 0.0;
+    pos += needle.size();
+    return std::stod(json.substr(pos));
+}
+
+// ---------------------------------------------------------------------------
+// Collect — input logging
+// ---------------------------------------------------------------------------
+
+void LogCanvasInput(
+    const std::string& op,
+    const std::string& text,
+    double x, double y,
+    const std::string& font,
+    int text_align,
+    int text_baseline,
+    double max_width
+) {
+    g_input_log.push_back({op, text, x, y, font,
+                            text_align, text_baseline,
+                            max_width, 0.0, 0.0});
+}
+
+void LogRectInput(double x, double y, double width, double height) {
+    g_input_log.push_back({"fillRect", "", x, y, "",
+                            0, 0, -1.0, width, height});
+}
+
+void FlushTestIfNew(const std::string& trigger, double render_ms) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    if (g_input_log.empty()) return;
+
+    std::string dir = GetOutputDir();
+    if (dir.empty()) return;
+
+    uint64_t h = HashInputLog();
+    char hash_hex[17];
+    snprintf(hash_hex, sizeof(hash_hex), "%016llx", (unsigned long long)h);
+
+    base::CreateDirectory(base::FilePath(dir));
+
+    std::string filepath = dir + hash_hex + "_" + trigger + ".json";
+
+    if (base::PathExists(base::FilePath(filepath))) {
+        g_input_log.clear();
+        return;
+    }
+
+    std::ostringstream ss;
+    ss << "{\n"
+       << "  \"site\": \"" << EscapeJson(g_current_site) << "\",\n"
+       << "  \"trigger\": \"" << trigger << "\",\n"
+       << "  \"hash\": \"" << hash_hex << "\",\n"
+       << "  \"render_ms\": " << render_ms << ",\n"
+       << "  \"calls\": [\n";
+    for (size_t i = 0; i < g_input_log.size(); i++) {
+        const auto& e = g_input_log[i];
+        ss << "    {\"op\":\"" << EscapeJson(e.op) << "\"";
+        if (!e.text.empty())
+            ss << ",\"text\":\"" << EscapeJson(e.text) << "\"";
+        if (!e.font.empty())
+            ss << ",\"font\":\"" << EscapeJson(e.font) << "\"";
+        if (e.op == "fillRect" || e.op == "drawImage") {
+            ss << ",\"x\":" << e.x
+               << ",\"y\":" << e.y
+               << ",\"w\":" << e.rect_width
+               << ",\"h\":" << e.rect_height;
+        } else {
+            ss << ",\"x\":" << e.x
+               << ",\"y\":" << e.y;
+            if (e.text_align != 0)
+                ss << ",\"text_align\":" << e.text_align;
+            if (e.text_baseline != 0)
+                ss << ",\"text_baseline\":" << e.text_baseline;
+            if (e.max_width >= 0)
+                ss << ",\"max_width\":" << e.max_width;
+        }
+        ss << "}";
+        if (i + 1 < g_input_log.size()) ss << ",";
+        ss << "\n";
+    }
+    ss << "  ]\n}";
+
+    std::ofstream f(filepath);
+    if (f.is_open())
+        f << ss.str();
+
+    g_input_log.clear();
+}
+
+// ---------------------------------------------------------------------------
+// Site management
+// ---------------------------------------------------------------------------
+
+void SetCurrentSite(const std::string& url) {
+    // Normalize to origin only (scheme + host + port) so that collect and
+    // replay hashes match across sessions regardless of path/query/token.
+    // Blob and data URLs produce opaque origins — fall back to raw string.
+    GURL gurl(url);
+    if (gurl.is_valid())
+        g_current_site = gurl.DeprecatedGetOriginAsURL().spec();
+    else
+        g_current_site = url;
+}
+
+void ClearInputLog() {
+    g_input_log.clear();
+}
