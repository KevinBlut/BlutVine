+static std::string GetCallerUrl() {
+    v8::Isolate* isolate = v8::Isolate::TryGetCurrent();
+    if (!isolate) return "";
+    std::array<v8::StackTrace::ScriptData, 8> stack_buffer;
+    auto stack = v8::StackTrace::CurrentScriptData(isolate, stack_buffer);
+    for (auto& frame : stack) {
+        if (frame.function.IsEmpty()) continue;
+        v8::ScriptOrigin origin = frame.function->GetScriptOrigin();
+        v8::Local<v8::Value> name = origin.ResourceName();
+        if (name.IsEmpty() || !name->IsString()) continue;
+        v8::String::Utf8Value url(isolate, name);
+        std::string s(*url, url.length());
+        if (s.rfind("http", 0) == 0) return s;
+    }
+    return "";
+}
