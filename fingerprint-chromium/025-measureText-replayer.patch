index 6738225b9e..859314ec25 100644
--- a/components/ungoogled/fingerprint_collector.cc
+++ b/components/ungoogled/fingerprint_collector.cc
@@ -335,4 +335,101 @@ std::vector<uint8_t> ReplayWebGLOutput() {
     return ReplayLookup("readPixels");
 }
 
+
+
+
+// ---------------------------------------------------------------------------
+// measureText Replay — OS + DPR path (CPU/font driven, not GPU)
+// ---------------------------------------------------------------------------
+
+static thread_local std::unordered_map<uint64_t, ReplayEntry> g_replay_map_measuretext;
+static thread_local std::string g_replay_loaded_site_measuretext;
+
+static std::string GetReplayDirMeasureText() {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintDatabase))
+        return "";
+    std::string db_path = cmd->GetSwitchValueASCII(switches::kFingerprintDatabase);
+    std::string platform = "unknown_os";
+    if (cmd->HasSwitch(switches::kFingerprintPlatformVersion))
+        platform = cmd->GetSwitchValueASCII(switches::kFingerprintPlatformVersion);
+    std::transform(platform.begin(), platform.end(), platform.begin(), ::tolower);
+    std::replace(platform.begin(), platform.end(), ' ', '_');
+    std::string dpr = "1_0";
+    if (cmd->HasSwitch(switches::kFingerprintScreenDevicePixelRatio)) {
+        dpr = cmd->GetSwitchValueASCII(switches::kFingerprintScreenDevicePixelRatio);
+        std::replace(dpr.begin(), dpr.end(), '.', '_');
+    }
+    std::string site = g_current_site.empty() ? "unknown" : SanitizeForPath(g_current_site);
+    return db_path + "/" + platform + "/" + dpr + "/" + site + "/";
+}
+
+static void ReplayLoadMeasureText() {
+    g_replay_map_measuretext.clear();
+    g_replay_loaded_site_measuretext = g_current_site;
+    std::string dir = GetReplayDirMeasureText();
+    if (dir.empty()) return;
+    base::FilePath dir_path(dir);
+    base::FileEnumerator enumerator(dir_path, false, base::FileEnumerator::FILES,
+                                    FILE_PATH_LITERAL("*.json"));
+    for (base::FilePath json_path = enumerator.Next();
+         !json_path.empty();
+         json_path = enumerator.Next()) {
+        std::string contents;
+        if (!base::ReadFileToString(json_path, &contents)) continue;
+        std::string hash_str = JsonGetString(contents, "hash");
+        if (hash_str.empty()) continue;
+        uint64_t hash = std::stoull(hash_str, nullptr, 16);
+        std::string bin_path = json_path.RemoveFinalExtension().value() + ".bin";
+        ReplayEntry entry;
+        entry.bin_path = bin_path;
+        entry.width    = JsonGetInt(contents, "width");
+        entry.height   = JsonGetInt(contents, "height");
+        entry.trigger  = JsonGetString(contents, "trigger");
+        g_replay_map_measuretext[hash] = std::move(entry);
+    }
+}
+
+static std::vector<double> ReplayLookupMeasureText() {
+    if (g_replay_loaded_site_measuretext != g_current_site)
+        ReplayLoadMeasureText();
+    uint64_t h = 0xcbf29ce484222325ULL;
+    for (const auto& e : g_input_log) {
+        h = FNV64(h, e.op.data(), e.op.size());
+        h = FNV64(h, e.text.data(), e.text.size());
+        h = FNV64(h, e.font.data(), e.font.size());
+        h = FNV64(h, &e.x, sizeof(e.x));
+        h = FNV64(h, &e.y, sizeof(e.y));
+        h = FNV64(h, &e.text_align, sizeof(e.text_align));
+        h = FNV64(h, &e.text_baseline, sizeof(e.text_baseline));
+        h = FNV64(h, &e.max_width, sizeof(e.max_width));
+        h = FNV64(h, &e.rect_width, sizeof(e.rect_width));
+        h = FNV64(h, &e.rect_height, sizeof(e.rect_height));
+    }
+    g_input_log.clear();
+    auto it = g_replay_map_measuretext.find(h);
+    if (it == g_replay_map_measuretext.end()) {
+        fprintf(stderr, "[FP-REPLAY-MEASURETEXT MISS] site=%s\n",
+                g_current_site.c_str());
+        return {};
+    }
+    const ReplayEntry& entry = it->second;
+    std::ifstream f(entry.bin_path, std::ios::binary);
+    if (!f.is_open()) {
+        fprintf(stderr, "[FP-REPLAY-MEASURETEXT MISS] bin missing: %s\n",
+                entry.bin_path.c_str());
+        return {};
+    }
+    std::vector<uint8_t> raw(
+        std::istreambuf_iterator<char>(f),
+        std::istreambuf_iterator<char>());
+    std::vector<double> result(raw.size() / sizeof(double));
+    memcpy(result.data(), raw.data(), result.size() * sizeof(double));
+    return result;
+}
+
+std::vector<double> ReplayMeasureText() {
+    return ReplayLookupMeasureText();
+}
+
 }  // namespace fingerprint_collector
