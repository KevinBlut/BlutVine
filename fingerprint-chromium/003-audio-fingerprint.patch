+// Compute a deterministic per-fingerprint noise offset for a given sample value.
+// Seed is value-dependent only (not position-dependent), so identical sample
+// values always get the same noise — preserving natural duplicates in the buffer
+// and keeping totalUniqueSamples well below bufferLen.
+static float getAudioSampleNoise(uint32_t base_seed, float quantized) {
+    uint32_t q_bits;
+#pragma clang diagnostic push
+#pragma clang diagnostic ignored "-Wunsafe-buffer-usage-in-libc-call"
+    memcpy(&q_bits, &quantized, sizeof(q_bits));
+#pragma clang diagnostic pop
+    uint32_t seed = base_seed ^ q_bits;
+    seed = seed * 1664525u + 1013904223u;
+    // Magnitude ±2.80e-08 per sample matches natural Blink hardware spread.
+    // Over 500 samples: total sampleSum shift stays within ±0.000028,
+    // indistinguishable from natural variation across real hardware.
+    return ((static_cast<float>(seed) / 4294967296.0f) - 0.5f) * 2.80e-08f;
+}
+
 OfflineAudioContext::OfflineAudioContext(LocalDOMWindow* window,
                                          unsigned number_of_channels,
                                          uint32_t number_of_frames,
@@ -411,6 +430,36 @@ void OfflineAudioContext::FireCompletionEvent() {
       return;
     }
 
+    const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+    if (command_line->HasSwitch(switches::kFingerprint)) {
+      std::string fingerprint = command_line->GetSwitchValueASCII(switches::kFingerprint);
+      if (!fingerprint.empty()) {
+        // Derive a stable per-session base seed from the fingerprint string.
+        std::string seed_str = fingerprint + "audio";
+        uint32_t base_seed = 2166136261u;
+        for (char c : seed_str) {
+          base_seed ^= static_cast<uint32_t>(c);
+          base_seed *= 16777619u;
+        }
+        for (unsigned ch = 0; ch < rendered_buffer->numberOfChannels(); ++ch) {
+          NotShared<DOMFloat32Array> array = rendered_buffer->getChannelData(ch);
+          float* data = array->Data();
+          size_t len = array->length();
+          UNSAFE_BUFFERS(
+          for (size_t i = 0; i < len; ++i) {
+            // Skip true-zero samples — preserves hasFakeAudio() check:
+            // a zero-frequency oscillator must produce all-zero output.
+            if (data[i] == 0.0f) continue;
+            float quantized = roundf(data[i] * 100000.0f) / 100000.0f;
+            // Skip samples that quantize to zero for the same reason.
+            if (quantized == 0.0f) continue;
+            data[i] = quantized + getAudioSampleNoise(base_seed, quantized);
+          }
+          );
+        }
+      }
+    }
+
     // Call the offline rendering completion event listener and resolve the
     // promise too.
     DispatchEvent(*OfflineAudioCompletionEvent::Create(rendered_buffer));
