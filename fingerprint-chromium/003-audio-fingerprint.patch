 void AnalyserNode::getFloatFrequencyData(NotShared<DOMFloat32Array> array) {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+
+  // Collect only: establish site context for DB bucketing.
+  if (cmd->HasSwitch(switches::kFingerprintCollect)) {
+    GURL raw(context()->GetExecutionContext()->Url().GetString().Utf8());
+    fingerprint_collector::SetCurrentSite(
+        raw.is_valid()
+            ? raw.DeprecatedGetOriginAsURL().spec()
+            : context()->GetExecutionContext()->Url().GetString().Utf8());
+  }
+
+  // Both modes: log test identity so HashInputLog() produces a meaningful key.
+  if (cmd->HasSwitch(switches::kFingerprintCollect) ||
+      cmd->HasSwitch(switches::kFingerprintReplay)) {
+    // length() == fftSize / 2 for frequency arrays.
+    fingerprint_collector::LogAudioInput(
+        1, static_cast<int>(array->length()), 0.0f);
+  }
+
   GetAnalyserHandler().GetFloatFrequencyData(array.Get(),
                                              context()->currentTime());
 }
 
