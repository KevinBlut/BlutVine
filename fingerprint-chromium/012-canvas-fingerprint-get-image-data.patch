+    // Per-pixel deterministic seed — spatially unique within session.
+    uint32_t h2 = render_hash;
+    h2 ^= static_cast<uint32_t>(x) * 2654435761u;
+    h2 ^= static_cast<uint32_t>(y) * 2246822519u;
+    h2 ^= h2 >> 16; h2 *= 0x45d9f3bu; h2 ^= h2 >> 16;
+
+    switch (colorType) {
+      case kRGBA_8888_SkColorType:
