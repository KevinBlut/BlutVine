+        r = clamp8(((h2 >> 10) & 1) ? r + ((h2 >> 7) & 1) : r - ((h2 >> 7) & 1));
+        g = clamp8(((h2 >> 11) & 1) ? g + ((h2 >> 8) & 1) : g - ((h2 >> 8) & 1));
