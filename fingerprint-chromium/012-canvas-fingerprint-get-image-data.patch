+        b = std::clamp(((h2 >> 12) & 1) ? b + ((int)((h2 >> 9) & 1)) : b - ((int)((h2 >> 9) & 1)), 0, 31);
+        *p = (r<<11)|(g<<5)|b;
+        break;
+      }
