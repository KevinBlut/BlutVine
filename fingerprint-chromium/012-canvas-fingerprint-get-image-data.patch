+        g = std::clamp(((h2 >> 11) & 1) ? g + ((int)((h2 >> 8) & 1)) : g - ((int)((h2 >> 8) & 1)), 0, 15);
+        b = std::clamp(((h2 >> 12) & 1) ? b + ((int)((h2 >> 9) & 1)) : b - ((int)((h2 >> 9) & 1)), 0, 15);
+        *p = (a<<12)|(r<<8)|(g<<4)|b;
+        break;
+      }
+
+      case kGray_8_SkColorType: {
+        uint8_t* p = static_cast<uint8_t*>(const_cast<void*>(addr)) + (y * fRowBytes) + x;
+        if (*p > 5 && *p < 250)
