+            h ^= static_cast<uint32_t>(y)      * 2246822519u;
+            h ^= h >> 16;
+            h *= 0x45d9f3bu;
+            h ^= h >> 16;
+
+            uint32_t mag_roll = h & 0xFF;
+            uint8_t mag = 0;
+
+            if (gpu_class == kSkFingerprintGpuClassIntel) {
+                if (mag_roll >= 80) {
+                    mag = 1;
+                }
+            } else if (gpu_class == kSkFingerprintGpuClassApple) {
+                if (mag_roll < 180) {
+                    mag = 1;
+                } else if (mag_roll < 248) {
+                    mag = 2;
+                } else {
+                    mag = 3;
+                }
+            } else {
+                if (mag_roll < 210) {
+                    mag = 1;
+                } else {
+                    mag = 2;
+                }
+            }
+
+            SkAlpha modified = alpha;
+            if (mag > 0) {
+                bool add = (h >> 8) & 1;
+                int new_alpha = add
+                    ? static_cast<int>(alpha) + mag
+                    : static_cast<int>(alpha) - mag;
+
+                if (new_alpha < 1)   new_alpha = 1;
+                if (new_alpha > 254) new_alpha = 254;
+
+                modified = static_cast<SkAlpha>(new_alpha);
+            }
+
+            // Store position and modified coverage for RGBA correction
+            SkStoreFingerprintPixel(x + i, y, modified);
+
+            add_alpha(&row[x + i], modified);
+        }
+    } else {
+        for (int i = 0; i < width; ++i) {
+            add_alpha(&row[x + i], alpha);
+        }
     }
 }
