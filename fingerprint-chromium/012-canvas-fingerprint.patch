@@ -523,6 +523,77 @@ ImageData* BaseRenderingContext2D::getImageDataInternal(
           snapshot->PaintImageForCurrentFrame().GetSkImageInfo().bounds();
       DCHECK(!bounds.intersect(SkIRect::MakeXYWH(sx, sy, sw, sh)));
     }
+
+    // Correct AA pixels to match our seed-modified coverage values exactly.
+    // This removes the GPU's own natural variance which was layered on top
+    // of our coverage offset, ensuring the reported output is purely our
+    // seed-modified result with no double modification.
+    const std::vector<SkFingerprintPixel>& fp_pixels = SkGetFingerprintPixels();
+    if (!fp_pixels.empty() && read_pixels_successful) {
+      uint8_t* rgba = static_cast<uint8_t*>(image_data_pixmap.writable_addr());
+      const size_t row_bytes = image_data_pixmap.rowBytes();
+      const int canvas_w = image_data_pixmap.width();
+      const int canvas_h = image_data_pixmap.height();
+
+      for (const SkFingerprintPixel& fp : fp_pixels) {
+        // Adjust for the readback origin (sx, sy)
+        int px = fp.x - sx;
+        int py = fp.y - sy;
+
+        // Skip pixels outside the readback region
+        if (px < 0 || py < 0 || px >= canvas_w || py >= canvas_h)
+          continue;
+
+        uint8_t* pixel = rgba + py * row_bytes + px * 4;
+
+        // Current GPU-rendered RGBA for this pixel
+        uint8_t gpu_r = pixel[0];
+        uint8_t gpu_g = pixel[1];
+        uint8_t gpu_b = pixel[2];
+        uint8_t gpu_a = pixel[3];
+
+        // Our coverage value — what the pixel SHOULD represent
+        uint8_t our_cov = fp.coverage;  // 1-254, genuine AA range
+
+        // Find the paint color and background color by examining neighbors.
+        // The nearest fully opaque pixel gives paint color.
+        // The nearest fully transparent pixel gives background color.
+        // For the correction we use a simpler approximation:
+        // Since GPU variance on coverage is only ±1-2 units and our coverage
+        // is already close to the GPU's input, the RGBA difference is minimal.
+        // We scale the GPU's RGB proportionally to our coverage vs what the
+        // GPU likely used, which corrects the variance contribution cleanly.
+
+        // Estimate GPU's actual coverage from its RGBA output.
+        // Use the alpha channel as the proxy for coverage since in standard
+        // canvas 2D rendering, alpha directly reflects coverage for AA pixels.
+        if (gpu_a == 0 || gpu_a == 255) {
+          // Solid or fully transparent — not an AA pixel we should touch
+          continue;
+        }
+
+        // gpu_a is the GPU's rendered alpha which directly encodes coverage.
+        // Scale RGB channels proportionally from gpu_a to our_cov.
+        // This removes the GPU variance and replaces with our exact coverage.
+        float scale = static_cast<float>(our_cov) /
+                      static_cast<float>(gpu_a);
+
+        auto clamp8 = [](float v) -> uint8_t {
+          int i = static_cast<int>(v + 0.5f);
+          if (i < 0)   return 0;
+          if (i > 255) return 255;
+          return static_cast<uint8_t>(i);
+        };
+
+        pixel[0] = clamp8(gpu_r * scale);
+        pixel[1] = clamp8(gpu_g * scale);
+        pixel[2] = clamp8(gpu_b * scale);
+        pixel[3] = our_cov;  // replace alpha directly with our coverage
+      }
+
+      // Done — clear stored pixels so next readback starts fresh
+      SkClearFingerprintPixels();
+    }
   }
 
   return image_data;
