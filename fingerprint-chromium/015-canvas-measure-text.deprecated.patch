+  
+  // Scale text metrics if enabled
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kFingerprint)) {
+    std::string seed_str = command_line->GetSwitchValueASCII(switches::kFingerprint);
+    std::string font_family = font->GetFontDescription().Family().FamilyName().Utf8();
+
+    std::string combined_x = seed_str + font_family + "clientrects_noise_x";
