+// ---------------------------------------------------------------------------
+// WebGL limit helpers — read switch value and return as int, or -1 if absent.
+// ---------------------------------------------------------------------------
+static int GetWebGLLimitInt(const char* switch_name) {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd->HasSwitch(switch_name)) return -1;
+  int val = -1;
+  base::StringToInt(cmd->GetSwitchValueASCII(switch_name), &val);
+  return val;
+}
+
+// Two comma-separated floats e.g. "1.0,10.0" -> pair, or {-1,-1} if absent.
+static std::pair<float, float> GetWebGLLimitFloatPair(const char* switch_name) {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd->HasSwitch(switch_name)) return {-1.f, -1.f};
+  std::string raw = cmd->GetSwitchValueASCII(switch_name);
+  auto parts = base::SplitString(raw, ",", base::TRIM_WHITESPACE,
+                                 base::SPLIT_WANT_NONEMPTY);
+  if (parts.size() < 2) return {-1.f, -1.f};
+  float a = -1.f, b = -1.f;
+  base::StringToFloat(parts[0], &a);
+  base::StringToFloat(parts[1], &b);
+  return {a, b};
+}
+
+// Two comma-separated ints e.g. "32768,32768" -> pair, or {-1,-1} if absent.
+static std::pair<int, int> GetWebGLLimitIntPair(const char* switch_name) {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd->HasSwitch(switch_name)) return {-1, -1};
+  std::string raw = cmd->GetSwitchValueASCII(switch_name);
+  auto parts = base::SplitString(raw, ",", base::TRIM_WHITESPACE,
+                                 base::SPLIT_WANT_NONEMPTY);
+  if (parts.size() < 2) return {-1, -1};
+  int a = -1, b = -1;
+  base::StringToInt(parts[0], &a);
+  base::StringToInt(parts[1], &b);
+  return {a, b};
+}
