+namespace {
+
+const ungoogled::fingerprint::GpuLimits* GetFingerprintGpuLimits() {
+    using namespace ungoogled::fingerprint;
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+
+    if (!cmd->HasSwitch(switches::kFingerprint))
+        return nullptr;
+
+    // Determine platform
+    std::string platform = cmd->HasSwitch(switches::kFingerprintPlatform)
+        ? cmd->GetSwitchValueASCII(switches::kFingerprintPlatform)
+        : "Linux x86_64";
+
+    bool is_windows = platform.find("Win") != std::string::npos ||
+                      platform.find("win") != std::string::npos;
+    bool is_mac     = platform.find("mac") != std::string::npos ||
+                      platform.find("Mac") != std::string::npos;
+
+    if (is_mac)
+        return &kGpuLimitsApple;
+
+    if (is_windows)
+        return &kGpuLimitsWindows;
+
+    // Linux — distinguish proprietary NVIDIA vs Mesa from renderer string.
+    // Check explicit renderer override first, then auto-built renderer.
+    // Mesa renderer strings contain "Mesa" or "nouveau".
+    bool is_mesa = false;
+    if (cmd->HasSwitch(switches::kFingerprintGpuRenderer)) {
+        std::string renderer =
+            cmd->GetSwitchValueASCII(switches::kFingerprintGpuRenderer);
+        is_mesa = renderer.find("Mesa") != std::string::npos ||
+                  renderer.find("nouveau") != std::string::npos;
+    }
+    // If using --fingerprint-gpu-model, the auto-built Linux renderer
+    // uses GetLinuxGpuString() which does NOT include "Mesa", so it
+    // always maps to proprietary NVIDIA limits — correct default for
+    // users spoofing a real NVIDIA identity on Linux.
+    // If you want Mesa limits, use explicit --fingerprint-gpu-renderer
+    // with a Mesa-format string.
+
+    return is_mesa ? &kGpuLimitsLinuxMesa : &kGpuLimitsLinuxNvidia;
+}
+
