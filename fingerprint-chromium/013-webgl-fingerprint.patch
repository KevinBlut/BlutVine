@@ -275,6 +275,78 @@ constexpr GpuModelInfo kGpuModels[] = {
 
 constexpr size_t kGpuModelCount = sizeof(kGpuModels) / sizeof(kGpuModels[0]);
 
+// =============================================================================
+// WebGL GPU Limits
+// =============================================================================
+// All NVIDIA architectures (Pascal through Blackwell) share the same WebGL
+// limits. The only meaningful distinction is the driver stack:
+//   - Windows ANGLE/D3D11:          aliased_line_width_range [1, 1]
+//   - Linux NVIDIA proprietary:     aliased_line_width_range [1, 10]
+//   - Linux Mesa/nouveau/zink:      aliased_line_width_range [1, 7.375]
+//
+// Detected from --fingerprint-gpu-model + --fingerprint-platform +
+// renderer string (presence of "Mesa" or "nouveau" signals Mesa stack).
+// =============================================================================
+
+struct GpuLimits {
+    int   max_texture_size;
+    int   max_render_buffer_size;
+    int   max_viewport_dims[2];
+    int   max_varying_vectors;
+    int   max_vertex_uniform_vectors;
+    int   max_fragment_uniform_vectors;
+    float aliased_line_width_range[2];
+    float aliased_point_size_range[2];
+};
+
+// Windows ANGLE/D3D11 — all NVIDIA architectures
+constexpr GpuLimits kGpuLimitsWindows = {
+    32768,          // MAX_TEXTURE_SIZE
+    32768,          // MAX_RENDER_BUFFER_SIZE
+    {32768, 32768}, // MAX_VIEWPORT_DIMS
+    31,             // MAX_VARYING_VECTORS
+    1024,           // MAX_VERTEX_UNIFORM_VECTORS
+    1024,           // MAX_FRAGMENT_UNIFORM_VECTORS
+    {1.0f, 1.0f},  // ALIASED_LINE_WIDTH_RANGE — D3D11 always [1, 1]
+    {1.0f, 2047.0f} // ALIASED_POINT_SIZE_RANGE
+};
+
+// Linux NVIDIA proprietary driver — all NVIDIA architectures
+constexpr GpuLimits kGpuLimitsLinuxNvidia = {
+    32768,          // MAX_TEXTURE_SIZE
+    32768,          // MAX_RENDER_BUFFER_SIZE
+    {32768, 32768}, // MAX_VIEWPORT_DIMS
+    31,             // MAX_VARYING_VECTORS
+    1024,           // MAX_VERTEX_UNIFORM_VECTORS
+    1024,           // MAX_FRAGMENT_UNIFORM_VECTORS
+    {1.0f, 10.0f}, // ALIASED_LINE_WIDTH_RANGE — NVIDIA proprietary
+    {1.0f, 2047.0f} // ALIASED_POINT_SIZE_RANGE
+};
+
+// Linux Mesa (nouveau/zink/Mesa NVIDIA) — all NVIDIA architectures
+constexpr GpuLimits kGpuLimitsLinuxMesa = {
+    32768,          // MAX_TEXTURE_SIZE
+    32768,          // MAX_RENDER_BUFFER_SIZE
+    {32768, 32768}, // MAX_VIEWPORT_DIMS
+    31,             // MAX_VARYING_VECTORS
+    1024,           // MAX_VERTEX_UNIFORM_VECTORS
+    1024,           // MAX_FRAGMENT_UNIFORM_VECTORS
+    {1.0f, 7.375f}, // ALIASED_LINE_WIDTH_RANGE — Mesa default
+    {1.0f, 2047.0f} // ALIASED_POINT_SIZE_RANGE
+};
+
+// Apple Silicon via Metal
+constexpr GpuLimits kGpuLimitsApple = {
+    16384,          // MAX_TEXTURE_SIZE
+    16384,          // MAX_RENDER_BUFFER_SIZE
+    {16384, 16384}, // MAX_VIEWPORT_DIMS
+    31,             // MAX_VARYING_VECTORS
+    1024,           // MAX_VERTEX_UNIFORM_VECTORS
+    1024,           // MAX_FRAGMENT_UNIFORM_VECTORS
+    {1.0f, 1.0f},  // ALIASED_LINE_WIDTH_RANGE — Metal always [1, 1]
+    {1.0f, 2047.0f} // ALIASED_POINT_SIZE_RANGE
+};
+
 }  // namespace fingerprint
 }  // namespace ungoogled
 
