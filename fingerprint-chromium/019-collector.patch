+#pragma once
+
+#include <string>
+#include <vector>
+#include "third_party/skia/include/core/SkImageInfo.h"
+#include "base/component_export.h"
+namespace fingerprint_collector {
+
+// Called at fillText hook points — logs input to thread-local buffer
+COMPONENT_EXPORT(UNGOOGLED) void LogCanvasInput(
+    const std::string& op,
+    const std::string& text,
+    double x, double y,
+    const std::string& font,
+    int text_align,
+    int text_baseline,
+    double max_width = -1.0
+);
+
+// Called at fillRect hook point
+COMPONENT_EXPORT(UNGOOGLED) void LogRectInput(
+    double x, double y,
+    double width, double height
+);
+
+// Called at toDataURL and getImageData output points
+COMPONENT_EXPORT(UNGOOGLED) void DumpCanvasOutput(
+    const void* addr,
+    const SkImageInfo& info,
+    const std::string& trigger
+);
+
+// Called at WebGL readPixels output point
+COMPONENT_EXPORT(UNGOOGLED) void DumpWebGLOutput(
+    const void* data,
+    int x, int y,
+    int width, int height,
+    unsigned int format,
+    unsigned int type
+);
+
+COMPONENT_EXPORT(UNGOOGLED) void SetCurrentSite(const std::string& url);
+
+// Clears thread-local input log — call at page navigation
+COMPONENT_EXPORT(UNGOOGLED) void ClearInputLog();
+
+}  // namespace fingerprint_collector
