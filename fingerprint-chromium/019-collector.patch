diff --git a/components/ungoogled/fingerprint_collector.cc b/components/ungoogled/fingerprint_collector.cc
new file mode 100644
index 0000000000..d33fc7aece
--- /dev/null
+++ b/components/ungoogled/fingerprint_collector.cc
@@ -0,0 +1,228 @@
+#include "components/ungoogled/fingerprint_collector.h"
+
+#include <algorithm>
+#include <atomic>
+#include <chrono>
+#include <fstream>
+#include <sstream>
+#include <string>
+#include <vector>
+
+#include "base/command_line.h"
+#include "components/ungoogled/ungoogled_switches.h"
+#include "third_party/skia/include/core/SkImageInfo.h"
+
+#include "base/files/file_util.h"
+#include "base/files/file_path.h"
+
+namespace fingerprint_collector {
+
+struct InputEntry {
+    std::string op;
+    std::string text;
+    double x, y;
+    std::string font;
+    int text_align;
+    int text_baseline;
+    double max_width;
+    double rect_width, rect_height;
+};
+
+static thread_local std::vector<InputEntry> g_input_log;
+static thread_local std::string g_current_site;
+static std::atomic<int> g_dump_counter{0};
+
+static std::string SanitizeForPath(const std::string& s) {
+    std::string out;
+    for (unsigned char c : s) {
+        if (c == '/' || c == '\\' || c == ':' || c == '*' ||
+            c == '?' || c == '"' || c == '<' || c == '>' || c == '|')
+            out += '_';
+        else
+            out += c;
+    }
+    return out;
+}
+
+static std::string GetOutputDir() {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+
+    if (!cmd->HasSwitch(switches::kFingerprintDatabase))
+        return "";
+
+    std::string db_path = cmd->GetSwitchValueASCII(switches::kFingerprintDatabase);
+
+    std::string gpu_model = "unknown_gpu";
+    if (cmd->HasSwitch(switches::kFingerprintGpuModel))
+        gpu_model = cmd->GetSwitchValueASCII(switches::kFingerprintGpuModel);
+
+    std::transform(gpu_model.begin(), gpu_model.end(),
+                   gpu_model.begin(), ::tolower);
+    std::replace(gpu_model.begin(), gpu_model.end(), ' ', '_');
+
+    std::string os_version = "unknown_os";
+    if (cmd->HasSwitch(switches::kFingerprintPlatformVersion))
+        os_version = cmd->GetSwitchValueASCII(switches::kFingerprintPlatformVersion);
+
+    std::transform(os_version.begin(), os_version.end(),
+                   os_version.begin(), ::tolower);
+    std::replace(os_version.begin(), os_version.end(), ' ', '_');
+
+    std::string site = g_current_site.empty() ? "unknown" : SanitizeForPath(g_current_site);
+    return db_path + "/" + gpu_model + "/" + os_version + "/" + site + "/";
+}
+
+static std::string EscapeJson(const std::string& s) {
+    std::string out;
+    for (unsigned char c : s) {
+        if (c == '"')        out += "\\\"";
+        else if (c == '\\')  out += "\\\\";
+        else if (c == '\n')  out += "\\n";
+        else if (c == '\r')  out += "\\r";
+        else if (c == '\t')  out += "\\t";
+        else if (c < 0x20)   { /* skip control chars */ }
+        else out += c;
+    }
+    return out;
+}
+
+static std::string SerializeInputLog() {
+    std::ostringstream ss;
+    ss << "[";
+    for (size_t i = 0; i < g_input_log.size(); i++) {
+        const auto& e = g_input_log[i];
+        if (i > 0) ss << ",";
+        ss << "{"
+           << "\"op\":\"" << EscapeJson(e.op) << "\","
+           << "\"text\":\"" << EscapeJson(e.text) << "\","
+           << "\"x\":" << e.x << ","
+           << "\"y\":" << e.y << ","
+           << "\"font\":\"" << EscapeJson(e.font) << "\","
+           << "\"text_align\":" << e.text_align << ","
+           << "\"text_baseline\":" << e.text_baseline << ","
+           << "\"max_width\":" << e.max_width << ","
+           << "\"rect_width\":" << e.rect_width << ","
+           << "\"rect_height\":" << e.rect_height
+           << "}";
+    }
+    ss << "]";
+    return ss.str();
+}
+
+static void WriteDump(
+    const std::string& trigger,
+    const std::string& input_json,
+    const void* pixel_data,
+    size_t pixel_size,
+    int width, int height,
+    const std::string& hash_hex,
+    const std::string& extra_meta = ""
+) {
+    std::string dir = GetOutputDir();
+    if (dir.empty()) return;
+
+    base::CreateDirectory(base::FilePath(dir));
+
+    std::string base = dir + hash_hex + "_" + trigger;
+
+    std::ofstream meta(base + ".json");
+    if (!meta.is_open()) return;
+    meta << "{"
+         << "\"trigger\":\"" << trigger << "\","
+         << "\"width\":" << width << ","
+         << "\"height\":" << height << ","
+         << "\"hash\":\"" << hash_hex << "\","
+         << "\"inputs\":" << input_json
+         << (extra_meta.empty() ? "" : "," + extra_meta)
+         << "}";
+    meta.close();
+
+    std::ofstream pixels(base + ".bin", std::ios::binary);
+    if (!pixels.is_open()) return;
+    pixels.write(static_cast<const char*>(pixel_data), pixel_size);
+    pixels.close();
+}
+
+void LogCanvasInput(
+    const std::string& op,
+    const std::string& text,
+    double x, double y,
+    const std::string& font,
+    int text_align,
+    int text_baseline,
+    double max_width
+) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    g_input_log.push_back({op, text, x, y, font,
+                            text_align, text_baseline,
+                            max_width, 0.0, 0.0});
+}
+
+void LogRectInput(double x, double y, double width, double height) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    g_input_log.push_back({"fillRect", "", x, y, "",
+                            0, 0, -1.0, width, height});
+}
+
+void DumpCanvasOutput(
+    const void* addr,
+    const SkImageInfo& info,
+    const std::string& trigger
+) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    if (!addr) return;
+
+    size_t size = info.computeMinByteSize();
+    if (size == 0) return;
+
+    uint64_t hash = HashInputLog();
+    std::string input_json = SerializeInputLog();
+    g_input_log.clear();
+
+    char hash_hex[17];
+    snprintf(hash_hex, sizeof(hash_hex), "%016llx", (unsigned long long)hash);
+
+    WriteDump(trigger, input_json, addr, size,
+              info.width(), info.height(), hash_hex);
+}
+
+void DumpWebGLOutput(
+    const void* data,
+    int x, int y,
+    int width, int height,
+    unsigned int format,
+    unsigned int type
+) {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kFingerprintCollect)) return;
+    if (!data) return;
+
+    size_t size = static_cast<size_t>(width) * height * 4;
+
+    uint64_t hash = HashInputLog();
+    std::string input_json = SerializeInputLog();
+    g_input_log.clear();
+
+    char hash_hex[17];
+    snprintf(hash_hex, sizeof(hash_hex), "%016llx", (unsigned long long)hash);
+
+    std::string meta = std::string("\"webgl_x\":" ) + std::to_string(x)
+        + ",\"webgl_y\":" + std::to_string(y)
+        + ",\"format\":" + std::to_string(format)
+        + ",\"type\":" + std::to_string(type);
+
+    WriteDump("readPixels", input_json, data, size, width, height, hash_hex, meta);
+}
+
+void SetCurrentSite(const std::string& url) {
+    g_current_site = url;
+}
+
+void ClearInputLog() {
+    g_input_log.clear();
+}
+
+}  // namespace fingerprint_collector
