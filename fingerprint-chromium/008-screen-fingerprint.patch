@@ -0,0 +1,33 @@
+// Copyright (c) 2020 The ungoogled-chromium Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef COMPONENTS_UNGOOGLED_FINGERPRINT_SCREEN_H_
+#define COMPONENTS_UNGOOGLED_FINGERPRINT_SCREEN_H_
+
+#include "base/component_export.h"
+#include "ui/display/screen_info.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace ungoogled {
+
+// Returns true if screen spoofing is active, i.e. at minimum
+// --fingerprint-screen-width and --fingerprint-screen-height are present.
+COMPONENT_EXPORT(UNGOOGLED) bool IsFingerprintScreenSpoofingEnabled();
+
+// Returns the spoofed device pixel ratio from --fingerprint-screen-device-pixel-ratio.
+COMPONENT_EXPORT(UNGOOGLED) float GetSpoofedDevicePixelRatio();
+
+// Returns a fully populated display::ScreenInfo built from switch values.
+COMPONENT_EXPORT(UNGOOGLED) display::ScreenInfo GetSpoofedScreenInfo();
+
+// Returns the spoofed outer window rect (outerWidth/Height, screenX/Y).
+COMPONENT_EXPORT(UNGOOGLED) gfx::Rect GetSpoofedWindowRect();
+
+// Returns the spoofed innerHeight. Uses avail height if supplied by caller,
+// otherwise estimates from window height.
+COMPONENT_EXPORT(UNGOOGLED) int GetSpoofedInnerHeight();
+
+}  // namespace ungoogled
+
+#endif  // COMPONENTS_UNGOOGLED_FINGERPRINT_SCREEN_H_
