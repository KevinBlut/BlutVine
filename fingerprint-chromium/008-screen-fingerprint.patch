+// found in the LICENSE file.
+
+#ifndef COMPONENTS_UNGOOGLED_FINGERPRINT_SCREEN_H_
+#define COMPONENTS_UNGOOGLED_FINGERPRINT_SCREEN_H_
+
+#include "ui/display/screen_info.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace ungoogled {
+
+// Returns true if screen spoofing is active.
+bool IsFingerprintScreenSpoofingEnabled();
+
+// Returns a spoofed ScreenInfo based on the fingerprint seed.
+display::ScreenInfo GetSpoofedScreenInfo();
+
+// Returns the spoofed window rect (for outerWidth/Height, screenX/Y).
+gfx::Rect GetSpoofedWindowRect();
+
+}  // namespace ungoogled
