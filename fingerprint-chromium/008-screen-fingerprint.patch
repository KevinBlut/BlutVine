diff --git a/components/ungoogled/fingerprint_screen.cc b/components/ungoogled/fingerprint_screen.cc
new file mode 100644
index 0000000000..26098a4ffd
--- /dev/null
+++ b/components/ungoogled/fingerprint_screen.cc
@@ -0,0 +1,99 @@
+#include "components/ungoogled/fingerprint_screen.h"
+
+#include "base/command_line.h"
+#include "base/hash/hash.h"
+#include "components/ungoogled/ungoogled_switches.h"
+#include "ui/display/screen_info.h"
+#include "ui/gfx/geometry/rect.h"
+#include "ui/gfx/geometry/size.h"
+
+namespace ungoogled {
+
+bool IsFingerprintScreenSpoofingEnabled() {
+  return base::CommandLine::ForCurrentProcess()->HasSwitch(
+      switches::kFingerprint);
+}
+
+uint32_t GetFingerprintSeed() {
+  std::string seed_str =
+      base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+          switches::kFingerprint);
+  return base::PersistentHash(seed_str);
+}
+
+float GetSpoofedDevicePixelRatio() {
+  uint32_t seed = GetFingerprintSeed();
+  // 80% 1.0, 10% 1.25, 5% 1.5, 5% 2.0
+  uint32_t r = (seed >> 8) % 100;
+  if (r < 80) return 1.0f;
+  if (r < 90) return 1.25f;
+  if (r < 95) return 1.5f;
+  return 2.0f;
+}
+
+display::ScreenInfo GetSpoofedScreenInfo() {
+  display::ScreenInfo info;
+  std::string seed_str =
+      base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+          switches::kFingerprint);
+  uint32_t seed = base::PersistentHash(seed_str);
+
+  int width = 0, height = 0, avail_width = 0, avail_height = 0;
+  float dpr = 0.0f;
+
+  // Check explicit overrides
+  if (cmd->HasSwitch(switches::kFingerprintScreenWidth))
+    base::StringToInt(cmd->GetSwitchValueASCII(switches::kFingerprintScreenWidth), &width);
+  if (cmd->HasSwitch(switches::kFingerprintScreenHeight))
+    base::StringToInt(cmd->GetSwitchValueASCII(switches::kFingerprintScreenHeight), &height);
+  if (cmd->HasSwitch(switches::kFingerprintScreenAvailWidth))
+    base::StringToInt(cmd->GetSwitchValueASCII(switches::kFingerprintScreenAvailWidth), &avail_width);
+  if (cmd->HasSwitch(switches::kFingerprintScreenAvailHeight))
+    base::StringToInt(cmd->GetSwitchValueASCII(switches::kFingerprintScreenAvailHeight), &avail_height);
+  if (cmd->HasSwitch(switches::kFingerprintScreenDevicePixelRatio))
+    base::StringToDouble(cmd->GetSwitchValueASCII(switches::kFingerprintScreenDevicePixelRatio), &dpr);
+
+  // Fallback to seed-based selection for missing values
+  if (width <= 0 || height <= 0) {
+    const struct {
+      int w, h;
+    } resolutions[] = {
+        {1920, 1080}, {1366, 768}, {1536, 864}, {1440, 900}, {2560, 1440}, {3840, 2160}
+    };
+    int idx = seed % std::size(resolutions);
+    width = resolutions[idx].w;
+    height = resolutions[idx].h;
+  }
+  if (avail_width <= 0) avail_width = width;
+  if (avail_height <= 0) avail_height = height - 40;  // typical taskbar
+  if (dpr <= 0.0f) dpr = GetSpoofedDevicePixelRatio();  // seed-based fallback
+
+  info.rect = gfx::Rect(0, 0, width, height);
+  info.available_rect = gfx::Rect(0, 0, avail_width, avail_height);
+  info.device_scale_factor = dpr;
+  info.depth = 24;
+  info.depth_per_component = 8;
+  info.is_monochrome = false;
+  info.orientation_angle = 0;
+  info.orientation_type = display::mojom::ScreenOrientation::kLandscapePrimary;
+  info.display_id = static_cast<int64_t>(seed & 0x7FFFFFFF);
+  info.is_extended = false;
+  info.is_primary = true;
+  info.is_internal = false;
+  info.display_frequency = 60.0f;
+  return info;
+}
+
+gfx::Rect GetSpoofedWindowRect() {
+  display::ScreenInfo info = GetSpoofedScreenInfo();
+
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  
+  // Assume browser window is positioned at (0,0) and takes most of screen.
+  // outerWidth/Height are window including decorations, so slightly smaller.
+  int width = info.rect.width() - 16;    // typical window border
+  int height = info.rect.height() - 80;  // title bar + taskbar
+  return gfx::Rect(0, 0, width, height);
+}
+
+}  // namespace ungoogled
