new file mode 100644
index 0000000000..f1062909a0
--- /dev/null
+++ b/components/ungoogled/fingerprint_screen.cc
@@ -0,0 +1,211 @@
+// Copyright (c) 2020 The ungoogled-chromium Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "components/ungoogled/fingerprint_screen.h"
+#include "components/ungoogled/fingerprint_data.h"
+#include <array>
+#include <cstddef>
+#include "base/strings/string_util.h"
+#include "base/command_line.h"
+#include "base/hash/hash.h"
+#include "base/strings/string_number_conversions.h"
+#include "components/ungoogled/ungoogled_switches.h"
+#include "third_party/blink/public/common/user_agent/user_agent_metadata.h"
+#include "ui/display/mojom/screen_orientation.mojom.h"
+#include "ui/display/screen_info.h"
+#include "ui/gfx/geometry/rect.h"
+#include "ui/gfx/geometry/size.h"
+
+namespace ungoogled {
+
+// ---------------------------------------------------------------------------
+// Android helpers
+// ---------------------------------------------------------------------------
+
+// Platform now comes from the launcher-supplied full UA string (UAForge
+// owns UA/CH construction end to end; BlutVine never selects platform
+// tokens itself) rather than a dedicated --fingerprint-platform switch.
+static bool IsAndroidPlatform() {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd->HasSwitch(switches::kFingerprintUA)) return false;
+  return blink::GetPlatformFromUA(
+      cmd->GetSwitchValueASCII(switches::kFingerprintUA)) == "android";
+}
+
+// Returns the AndroidModel entry matching Sec-CH-UA-Model
+// (--fingerprint-ch-model), or the default (pixel8) if the switch is
+// absent or the key is unknown.
+static const fingerprint::AndroidModel* GetAndroidModelEntry() {
+  using namespace fingerprint;
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+
+  std::string key = "pixel8";  // default
+  if (cmd->HasSwitch(switches::kFingerprintCHUAModel)) {
+    std::string raw = base::ToLowerASCII(
+        cmd->GetSwitchValueASCII(switches::kFingerprintCHUAModel));
+    // Normalize: strip spaces and dashes
+    std::string normalized;
+    for (char c : raw)
+      if (c != ' ' && c != '-') normalized += c;
+    if (!normalized.empty()) key = normalized;
+  }
+
+  for (const auto& m : kAndroidModels) {
+    if (key == m.key) return &m;
+  }
+
+  // Fallback: pixel8
+  for (const auto& m : kAndroidModels) {
+    if (std::string("pixel8") == m.key) return &m;
+  }
+  return &kAndroidModels[0];
+}
+
+// ---------------------------------------------------------------------------
+
+bool IsFingerprintScreenSpoofingEnabled() {
+  return base::CommandLine::ForCurrentProcess()->HasSwitch(
+      switches::kFingerprint);
+}
+
+static uint32_t GetFingerprintSeed() {
+  const std::string seed_str =
+      base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+          switches::kFingerprint);
+  return base::PersistentHash(seed_str);
+}
+
+float GetSpoofedDevicePixelRatio() {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+
+  if (cmd->HasSwitch(switches::kFingerprintScreenDevicePixelRatio)) {
+    double val = 0.0;
+    if (base::StringToDouble(
+            cmd->GetSwitchValueASCII(
+                switches::kFingerprintScreenDevicePixelRatio),
+            &val) &&
+        val > 0.0) {
+      return static_cast<float>(val);
+    }
+  }
+
+  // Android: use model DPR
+  if (IsAndroidPlatform())
+    return GetAndroidModelEntry()->dpr;
+
+  // Seed-based fallback: 80% -> 1.0, 10% -> 1.25, 5% -> 1.5, 5% -> 2.0
+  const uint32_t r = (GetFingerprintSeed() >> 8) % 100;
+  if (r < 80) return 1.0f;
+  if (r < 90) return 1.25f;
+  if (r < 95) return 1.5f;
+  return 2.0f;
+}
+
+display::ScreenInfo GetSpoofedScreenInfo() {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  const uint32_t seed = GetFingerprintSeed();
+
+  // Android: use model-specific dimensions and portrait orientation
+  if (IsAndroidPlatform()) {
+    const auto* m = GetAndroidModelEntry();
+    display::ScreenInfo info;
+    info.rect                = gfx::Rect(0, 0, m->screen_width, m->screen_height);
+    // availHeight excludes the Android nav bar
+    info.available_rect      = gfx::Rect(0, 0, m->screen_width,
+                                         m->screen_height - m->nav_bar_height);
+    info.device_scale_factor = m->dpr;
+    info.depth               = 24;
+    info.depth_per_component = 8;
+    info.is_monochrome       = false;
+    info.orientation_angle   = 0;
+    info.orientation_type    =
+        display::mojom::ScreenOrientation::kPortraitPrimary;
+    info.display_id          = static_cast<int64_t>(seed & 0x7FFFFFFF);
+    info.is_extended         = false;
+    info.is_primary          = true;
+    info.is_internal         = true;  // mobile display is always internal
+    return info;
+  }
+
+  int width = 0, height = 0, avail_width = 0, avail_height = 0;
+
+  // Explicit overrides take priority.
+  if (cmd->HasSwitch(switches::kFingerprintScreenWidth))
+    base::StringToInt(
+        cmd->GetSwitchValueASCII(switches::kFingerprintScreenWidth), &width);
+  if (cmd->HasSwitch(switches::kFingerprintScreenHeight))
+    base::StringToInt(
+        cmd->GetSwitchValueASCII(switches::kFingerprintScreenHeight), &height);
+  if (cmd->HasSwitch(switches::kFingerprintScreenAvailWidth))
+    base::StringToInt(
+        cmd->GetSwitchValueASCII(switches::kFingerprintScreenAvailWidth),
+        &avail_width);
+  if (cmd->HasSwitch(switches::kFingerprintScreenAvailHeight))
+    base::StringToInt(
+        cmd->GetSwitchValueASCII(switches::kFingerprintScreenAvailHeight),
+        &avail_height);
+
+  // Seed-based fallback for width/height.
+  if (width <= 0 || height <= 0) {
+    struct Resolution { int w, h; };
+    static constexpr std::array<Resolution, 4> kDesktopResolutions = {{
+        {1920, 1080}, {1440, 900}, {2560, 1440}, {3840, 2160},
+    }};
+    static constexpr std::array<Resolution, 4> kLaptopResolutions = {{
+        {1920, 1080}, {1366, 768}, {1536, 864}, {1440, 900},
+    }};
+    bool is_laptop = cmd->HasSwitch(switches::kFingerprintLaptop);
+    const auto& resolutions = is_laptop ? kLaptopResolutions : kDesktopResolutions;
+    const auto& res = resolutions[seed % resolutions.size()];
+    width  = res.w;
+    height = res.h;
+  }
+  if (avail_width  <= 0) avail_width  = width;
+  if (avail_height <= 0) avail_height = height - 40;  // typical taskbar height
+
+  display::ScreenInfo info;
+  info.rect                = gfx::Rect(0, 0, width, height);
+  info.available_rect      = gfx::Rect(0, 0, avail_width, avail_height);
+  info.device_scale_factor = GetSpoofedDevicePixelRatio();
+  info.depth               = 24;
+  info.depth_per_component = 8;
+  info.is_monochrome       = false;
+  info.orientation_angle   = 0;
+  info.orientation_type    =
+      display::mojom::ScreenOrientation::kLandscapePrimary;
+  info.display_id          = static_cast<int64_t>(seed & 0x7FFFFFFF);
+  info.is_extended         = false;
+  info.is_primary          = true;
+  info.is_internal         = false;
+  return info;
+}
+
+gfx::Rect GetSpoofedWindowRect() {
+  const display::ScreenInfo info = GetSpoofedScreenInfo();
+
+  // Android: outerWidth/Height == full screen dimensions (no window chrome)
+  if (IsAndroidPlatform()) {
+    return gfx::Rect(0, 0, info.rect.width(), info.rect.height());
+  }
+
+  // Outer window includes decorations: subtract typical border + title/taskbar.
+  const int width  = info.rect.width()  - 16;
+  const int height = info.rect.height() - 80;
+  return gfx::Rect(0, 0, width, height);
+}
+
+int GetSpoofedInnerHeight() {
+  // Android: subtract status bar + address bar + nav bar
+  if (IsAndroidPlatform()) {
+    const auto* m = GetAndroidModelEntry();
+    return m->screen_height
+           - m->status_bar_height
+           - m->address_bar_height
+           - m->nav_bar_height;
+  }
+  // Desktop: fixed estimate
+  return GetSpoofedWindowRect().height() - 85;
+}
+
+}  // namespace ungoogled
