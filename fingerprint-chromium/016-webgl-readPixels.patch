diff --git a/third_party/blink/renderer/modules/webgl/webgl_rendering_context_base.cc b/third_party/blink/renderer/modules/webgl/webgl_rendering_context_base.cc
index 740061e455..2f0c7c365c 100644
--- a/third_party/blink/renderer/modules/webgl/webgl_rendering_context_base.cc
+++ b/third_party/blink/renderer/modules/webgl/webgl_rendering_context_base.cc
@@ -34,6 +34,9 @@
 #include "components/ungoogled/fingerprint_data.h"
 #include "components/ungoogled/ungoogled_switches.h"
 
+#include "base/strings/string_number_conversions.h"
+#include "third_party/skia/src/core/SkFingerprintSeed.h"
+
 #include "base/bit_cast.h"
 #include "base/byte_size.h"
 #include "base/compiler_specific.h"
@@ -5195,6 +5198,140 @@ void WebGLRenderingContextBase::ReadPixelsHelper(GLint x,
       return;
     }
     ContextGL()->ReadPixels(x, y, width, height, format, type, data);
+
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (cmd->HasSwitch(switches::kFingerprint) &&
+        format == GL_RGBA && type == GL_UNSIGNED_BYTE &&
+        data && width > 0 && height > 0) {
+
+        if (width < 8 || height < 8) goto done;
+
+        {
+        // ── 1. GPU class ──────────────────────────────────────────────────────
+        uint8_t gpu_class = kSkFingerprintGpuClassNvidia;
+        if (cmd->HasSwitch(switches::kFingerprintGpuRenderer)) {
+            std::string renderer = cmd->GetSwitchValueASCII(
+                switches::kFingerprintGpuRenderer);
+            if (renderer.find("Intel") != std::string::npos)
+                gpu_class = kSkFingerprintGpuClassIntel;
+            else if (renderer.find("Apple") != std::string::npos)
+                gpu_class = kSkFingerprintGpuClassApple;
+        }
+
+        // ── 2. Seed + dimension-incorporated hash ─────────────────────────────
+        std::string seed_str = cmd->GetSwitchValueASCII(switches::kFingerprint);
+        std::string combined = seed_str + "_"
+                             + std::to_string(width) + "_"
+                             + std::to_string(height);
+        uint64_t render_hash = 2166136261u;
+        for (char c : combined) {
+            render_hash ^= static_cast<uint64_t>(c);
+            render_hash *= 16777619u;
+        }
+        std::mt19937_64 rng(render_hash);
+
+        // ── 3. Pixel budget ───────────────────────────────────────────────────
+        double area = static_cast<double>(width) * height;
+        double scale_factor = std::log10(std::max(10.0, area));
+        int base_pixels = std::clamp(static_cast<int>(scale_factor * 4.6), 5, 20);
+        int var_range = base_pixels / 5;
+        int jitter = static_cast<int>(render_hash % (var_range * 2 + 1)) - var_range;
+        int max_pixels = std::clamp(base_pixels + jitter, 5, 20);
+
+        // ── 4. Luminance helper (RGBA_8888) ───────────────────────────────────
+        auto get_lum = [&](int px, int py) -> int {
+            const uint8_t* p = data + py * width * 4 + px * 4;
+            return (p[0] + p[1] + p[2]) / 3;
+        };
+
+        // ── 5. Collect AA pixels ──────────────────────────────────────────────
+        constexpr int BOUNDARY_THRESHOLD = 10;
+        constexpr int BLEND_MARGIN       = 2;
+        constexpr int HARD_EDGE_TOL      = 3;
+        int scan_stride = (area < 10000) ? 1
+                        : std::max(2, static_cast<int>(area / 8000));
+
+        std::vector<std::pair<int,int>> aa_pixels;
+        aa_pixels.reserve(static_cast<size_t>(max_pixels * 2));
+
+        for (int py = 1; py < height - 1 && (int)aa_pixels.size() < max_pixels * 4; py += scan_stride) {
+            for (int px = 1; px < width - 1 && (int)aa_pixels.size() < max_pixels * 4; px += scan_stride) {
+                int c      = get_lum(px,     py);
+                int left   = get_lum(px - 1, py);
+                int right  = get_lum(px + 1, py);
+                int top    = get_lum(px,     py - 1);
+                int bottom = get_lum(px,     py + 1);
+                bool is_aa = false;
+                if (std::abs(left - right) > BOUNDARY_THRESHOLD) {
+                    int lo = std::min(left, right) + BLEND_MARGIN;
+                    int hi = std::max(left, right) - BLEND_MARGIN;
+                    if (c > lo && c < hi &&
+                        std::abs(c - left)  > HARD_EDGE_TOL &&
+                        std::abs(c - right) > HARD_EDGE_TOL)
+                        is_aa = true;
+                }
+                if (!is_aa && std::abs(top - bottom) > BOUNDARY_THRESHOLD) {
+                    int lo = std::min(top, bottom) + BLEND_MARGIN;
+                    int hi = std::max(top, bottom) - BLEND_MARGIN;
+                    if (c > lo && c < hi &&
+                        std::abs(c - top)    > HARD_EDGE_TOL &&
+                        std::abs(c - bottom) > HARD_EDGE_TOL)
+                        is_aa = true;
+                }
+                if (is_aa)
+                    aa_pixels.push_back({px, py});
+            }
+        }
+
+        // ── 6. Apply noise ────────────────────────────────────────────────────
+        if (!aa_pixels.empty()) {
+            std::shuffle(aa_pixels.begin(), aa_pixels.end(), rng);
+            if ((int)aa_pixels.size() > max_pixels)
+                aa_pixels.resize(static_cast<size_t>(max_pixels));
+
+            for (const auto& [px, py] : aa_pixels) {
+                uint64_t p_seed = render_hash
+                                ^ (static_cast<uint64_t>(px) * 73856093ULL)
+                                ^ (static_cast<uint64_t>(py) * 19349663ULL);
+
+                uint32_t mag_roll = p_seed & 0xFF;
+                uint8_t mag = 0;
+                if (gpu_class == kSkFingerprintGpuClassIntel) {
+                    if (mag_roll >= 80) mag = 1;
+                } else if (gpu_class == kSkFingerprintGpuClassApple) {
+                    if (mag_roll < 180)      mag = 1;
+                    else if (mag_roll < 248) mag = 2;
+                    else                     mag = 3;
+                } else {
+                    // NVIDIA/AMD: 82% ±1, 18% ±2
+                    if (mag_roll < 210) mag = 1;
+                    else                mag = 2;
+                }
+                if (mag == 0) continue;
+
+                bool    add = (p_seed >> 8)  & 1;
+                uint8_t jR  = (p_seed >> 9)  & 1;
+                uint8_t jG  = (p_seed >> 10) & 1;
+                uint8_t jB  = (p_seed >> 11) & 1;
+
+                uint8_t* pixel = data + py * width * 4 + px * 4;
+                uint8_t r = pixel[0], g = pixel[1], b = pixel[2];
+
+                if ((r < 5 && g < 5 && b < 5) || (r > 250 && g > 250 && b > 250))
+                    continue;
+
+                auto clamp8 = [](int v) -> uint8_t {
+                    return static_cast<uint8_t>(std::clamp(v, 0, 255));
+                };
+                pixel[0] = clamp8(add ? r + mag + jR : r - mag - jR);
+                pixel[1] = clamp8(add ? g + mag + jG : g - mag - jG);
+                pixel[2] = clamp8(add ? b + mag + jB : b - mag - jB);
+                // alpha unchanged
+            }
+        }
+        }
+        done:;
+    }
   }
 }
 
