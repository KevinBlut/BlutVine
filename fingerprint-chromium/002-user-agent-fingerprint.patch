+constexpr const char* kEdgeDisplayName = "Microsoft Edge";
+constexpr const char* kOperaDisplayName = "Opera";
+constexpr const char* kVivaldiDisplayName = "Vivaldi";
+
+// =============================================================================
+// Browser Default Versions
