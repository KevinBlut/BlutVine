+// fingerprint_mobile.h
+//
+// Shared Android profile resolver used by both user_agent_utils.cc and
+// user_agent_metadata.cc. Header-only so both TUs get the same definition
+// without a new link dependency.
+
+#pragma once
+
+#include <string>
+
+#include "base/command_line.h"
+#include "base/strings/string_util.h"
+#include "components/ungoogled/fingerprint_data.h"
+#include "components/ungoogled/ungoogled_switches.h"
+
+namespace fingerprint_mobile {
+
+struct AndroidProfile {
+  std::string android_version;  // e.g. "14"     — UA string token
+  std::string ch_version;       // e.g. "14.0.0" — Sec-CH-UA-Platform-Version
+  std::string model_ua;         // e.g. "Pixel 8" — UA string model token
+};
+
+// Resolves Android version and device model from --fingerprint-platform value
+// plus the optional --fingerprint-mobile-model override.
+//
+// platform_value must already be lowercased by the caller.
+//
+// Version parsing examples:
+//   "android"    -> kAndroidDefaultMajor (14)
+//   "android14"  -> 14
+//   "android13"  -> 13
+//   "android 15" -> 15  (space between token and number is fine)
+//
+// Model key normalization (--fingerprint-mobile-model):
+//   "pixel8pro", "pixel 8 pro", "pixel-8-pro" all resolve to key "pixel8pro".
+//   Unknown keys fall back silently to the version default model.
+inline AndroidProfile ResolveAndroidProfile(const std::string& platform_value) {
+  using namespace ungoogled::fingerprint;
+
+  // --- resolve version ---
+  int requested_major = kAndroidDefaultMajor;
+  for (const auto& av : kAndroidVersions) {
+    if (platform_value.find(std::to_string(av.major)) != std::string::npos) {
+      requested_major = av.major;
+      break;
+    }
+  }
+
+  const AndroidVersionEntry* ver = nullptr;
+  for (const auto& av : kAndroidVersions) {
+    if (av.major == requested_major) {
+      ver = &av;
+      break;
+    }
+  }
+  // kAndroidVersions always contains kAndroidDefaultMajor so ver is never null,
+  // but guard anyway to keep static analysis happy.
+  if (!ver) ver = &kAndroidVersions[1];  // Android 14
+
+  // --- resolve model ---
+  std::string model_ua = ver->default_model_ua;
+
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (cmd->HasSwitch(switches::kFingerprintMobileModel)) {
+    std::string raw = base::ToLowerASCII(
+        cmd->GetSwitchValueASCII(switches::kFingerprintMobileModel));
+    // Normalize: drop spaces and dashes so "pixel 8 pro" == "pixel-8-pro" == "pixel8pro"
+    std::string key;
+    for (char c : raw)
+      if (c != ' ' && c != '-') key += c;
+    for (const auto& m : kAndroidModels) {
+      if (key == m.key) { model_ua = m.ua_name; break; }
+    }
+  }
+
+  return { ver->ua_version, ver->ch_version, model_ua };
+}
+
+}  // namespace fingerprint_mobile
