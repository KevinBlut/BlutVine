+// ---------------------------------------------------------------------------
+// BlutVine helpers
+// ---------------------------------------------------------------------------
+
+std::string GetPlatformFromUA(const std::string& ua) {
+  if (ua.find("Windows") != std::string::npos)   return "windows";
+  if (ua.find("Android") != std::string::npos)   return "android";
+  if (ua.find("Macintosh") != std::string::npos) return "macos";
+  if (ua.find("X11") != std::string::npos)       return "linux";
+  return "";
+}
+
+std::string GetBrandFromUA(const std::string& ua) {
+  if (ua.find(" Edg/") != std::string::npos)     return "edge";
+  if (ua.find(" OPR/") != std::string::npos)     return "opera";
+  if (ua.find(" Vivaldi/") != std::string::npos) return "vivaldi";
+  return "chrome";
+}
+
+void UpdateUserAgentMetadataFingerprint(UserAgentMetadata* metadata) {
+  if (!metadata)
+    return;
+
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd->HasSwitch(switches::kFingerprintUA))
+    return;
+
+  const std::string ua = cmd->GetSwitchValueASCII(switches::kFingerprintUA);
+  const std::string platform = GetPlatformFromUA(ua);
+  const std::string brand    = GetBrandFromUA(ua);
+
+  // --- Platform ---
+  if (platform == "windows") {
+    metadata->platform     = "Windows";
+    metadata->architecture = "x86";
+    metadata->bitness      = "64";
+    metadata->mobile       = false;
+    metadata->wow64        = false;
+    metadata->form_factors = {std::string(blink::kDesktopFormFactor)};
+  } else if (platform == "macos" || platform == "macarm") {
+    metadata->platform     = "macOS";
+    metadata->architecture = (platform == "macarm") ? "arm" : "x86";
+    metadata->bitness      = "64";
+    metadata->mobile       = false;
+    metadata->wow64        = false;
+    metadata->form_factors = {std::string(blink::kDesktopFormFactor)};
+  } else if (platform == "linux") {
+    metadata->platform     = "Linux";
+    metadata->architecture = "x86";
+    metadata->bitness      = "64";
+    metadata->mobile       = false;
+    metadata->wow64        = false;
+    metadata->form_factors = {std::string(blink::kDesktopFormFactor)};
+  } else if (platform == "android") {
+    metadata->platform     = "Android";
+    metadata->architecture = "arm";
+    metadata->bitness      = "64";
+    metadata->mobile       = true;
+    metadata->wow64        = false;
+    metadata->form_factors = {std::string(blink::kMobileFormFactor)};
+  }
+
+  // --- Platform version (Sec-CH-UA-Platform-Version) ---
+  // Supplied directly by launcher; if absent, Chromium default applies.
+  if (cmd->HasSwitch(switches::kFingerprintPlatformVersion))
+    metadata->platform_version =
+        cmd->GetSwitchValueASCII(switches::kFingerprintPlatformVersion);
+
+  // --- CH overrides — only needed when launcher wants to explicitly
+  //     deviate from what the platform block set above. ---
+
+  if (cmd->HasSwitch(switches::kFingerprintCHUAArch))
+    metadata->architecture =
+        cmd->GetSwitchValueASCII(switches::kFingerprintCHUAArch);
+
+  if (cmd->HasSwitch(switches::kFingerprintCHUABitness))
+    metadata->bitness =
+        cmd->GetSwitchValueASCII(switches::kFingerprintCHUABitness);
+
+  if (cmd->HasSwitch(switches::kFingerprintCHUAModel))
+    metadata->model =
+        cmd->GetSwitchValueASCII(switches::kFingerprintCHUAModel);
+
+  if (cmd->HasSwitch(switches::kFingerprintCHUAMobile)) {
+    std::string m = cmd->GetSwitchValueASCII(switches::kFingerprintCHUAMobile);
+    metadata->mobile = (m == "?1" || m == "1" || m == "true");
+  }
+
+  if (cmd->HasSwitch(switches::kFingerprintCHUAWoW64)) {
+    std::string w = cmd->GetSwitchValueASCII(switches::kFingerprintCHUAWoW64);
+    metadata->wow64 = (w == "?1" || w == "1" || w == "true");
+  }
+
+  if (cmd->HasSwitch(switches::kFingerprintCHUAFormFactors)) {
+    std::string ff =
+        cmd->GetSwitchValueASCII(switches::kFingerprintCHUAFormFactors);
+    metadata->form_factors.clear();
+    for (const auto& token : base::SplitString(
+             ff, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY)) {
+      if (UserAgentMetadata::IsValidFormFactor(token))
+        metadata->form_factors.push_back(token);
+    }
+  }
+
+  // --- Full version list (Sec-CH-UA-Full-Version-List) ---
+  // Only needed when brand is non-Chrome. If absent, Chromium default applies.
+  if (cmd->HasSwitch(switches::kFingerprintCHUAFullVersionList)) {
+    std::string raw =
+        cmd->GetSwitchValueASCII(switches::kFingerprintCHUAFullVersionList);
+    auto parsed = net::structured_headers::ParseList(raw);
+    if (parsed) {
+      metadata->brand_full_version_list.clear();
+      for (const auto& member : *parsed) {
+        if (member.member.empty()) continue;
+        const auto& item = member.member[0].item;
+        if (!item.is_string()) continue;
+        std::string b = item.GetString();
+        std::string v;
+        for (const auto& param : member.params) {
+          if (param.first == "v" && param.second.is_string())
+            v = param.second.GetString();
+        }
+        metadata->brand_full_version_list.push_back({b, v});
+      }
+    }
+  }
+}
+
 }  // namespace blink
