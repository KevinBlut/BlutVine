 String Navigator::platform() const {
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+
+  if (command_line->HasSwitch(switches::kFingerprintPlatform)) {
+    std::string custom_platform = base::ToLowerASCII(command_line->GetSwitchValueASCII(switches::kFingerprintPlatform));
+
+    if (custom_platform.find("win") != std::string::npos)
+      return "Win32";
+    if (custom_platform.find("linux") != std::string::npos ||
+        custom_platform.find("x11") != std::string::npos ||
+        custom_platform.find("ubuntu") != std::string::npos ||
+        custom_platform.find("debian") != std::string::npos)
+      return "Linux x86_64";
+    if (custom_platform.find("mac") != std::string::npos)
+      return "MacIntel";
+
+    if (!custom_platform.empty())
+      return String::FromUTF8(custom_platform);
+  }
