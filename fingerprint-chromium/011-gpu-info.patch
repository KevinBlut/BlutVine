diff --git a/third_party/blink/renderer/modules/webgl/gpu_fingerprint.cc b/third_party/blink/renderer/modules/webgl/gpu_fingerprint.cc
new file mode 100644
index 0000000000..5c3e2f3089
--- /dev/null
+++ b/third_party/blink/renderer/modules/webgl/gpu_fingerprint.cc
@@ -0,0 +1,197 @@
+#include "third_party/blink/renderer/modules/webgl/gpu_fingerprint.h"
+
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_util.h"
+#include "components/ungoogled/fingerprint_data.h"
+#include "components/ungoogled/ungoogled_switches.h"
+#include "third_party/blink/renderer/modules/webgl/gpu_info.h"
+
+#include <vector>
+#include <string>
+
+// GPU deviceID信息可以在这里查询
+// 570.144是驱动号，替换成最新的驱动号
+// https://download.nvidia.com/XFree86/Linux-x86_64/570.144/README/supportedchips.html
+// https://deviceandbrowserinfo.com/data/fingerprints/attribute/webGLRenderer
+// https://devicehunt.com/view/type/pci/vendor/10DE
+
+namespace blink {
+
+using ungoogled::fingerprint::kMacosGpuModelCount;
+using ungoogled::fingerprint::kMacosGpuModelCount;
+using ungoogled::fingerprint::kGpuModels;
+using ungoogled::fingerprint::kGpuModelCount;
+
+namespace {
+
+// Returns true if the model name looks like a laptop GPU variant
+bool IsLaptopModel(const std::string& model_name) {
+    return model_name.find("Laptop") != std::string::npos ||
+           model_name.find("laptop") != std::string::npos ||
+           model_name.find("Mobile") != std::string::npos;
+}
+
+// Normalize input for fuzzy matching:
+// strips spaces, lowercases, strips "geforce", "nvidia", "gtx", "rtx"
+std::string NormalizeModelInput(const std::string& input) {
+    std::string result = base::ToLowerASCII(input);
+    // Remove common prefix words users might or might not type
+    for (const auto& prefix : {"geforce ", "nvidia ", "gtx ", "rtx "}) {
+        auto pos = result.find(prefix);
+        while (pos != std::string::npos) {
+            result.erase(pos, strlen(prefix));
+            pos = result.find(prefix);
+        }
+    }
+    // Collapse multiple spaces
+    std::string out;
+    bool last_space = false;
+    for (char c : result) {
+        if (c == ' ') {
+            if (!last_space) out += c;
+            last_space = true;
+        } else {
+            out += c;
+            last_space = false;
+        }
+    }
+    // Trim trailing space
+    if (!out.empty() && out.back() == ' ')
+        out.pop_back();
+    return out;
+}
+
+// Selects a GPU model index from kGpuModels[] based on:
+//   - model_input: user-provided model hint e.g. "RTX 3060", "GTX 1660 Ti"
+//   - prefer_laptop: whether to prefer laptop GPU variants
+//   - seed: fingerprint seed for deterministic selection among matches
+// Returns kGpuModelCount if no match found.
+size_t SelectGpuModelIndex(const std::string& model_input,
+                            bool prefer_laptop,
+                            uint32_t seed) {
+    std::string normalized_input = NormalizeModelInput(model_input);
+
+    // Collect matching indices — split into laptop and desktop lists
+    std::vector<size_t> laptop_matches;
+    std::vector<size_t> desktop_matches;
+
+    for (size_t i = 0; i < kGpuModelCount; ++i) {
+        std::string model_lower = base::ToLowerASCII(
+            std::string(kGpuModels[i].model_name));
+        std::string normalized_model = NormalizeModelInput(model_lower);
+
+        // Check if the normalized input is a substring of the normalized model
+        if (normalized_model.find(normalized_input) != std::string::npos) {
+            if (IsLaptopModel(kGpuModels[i].model_name)) {
+                laptop_matches.push_back(i);
+            } else {
+                desktop_matches.push_back(i);
+            }
+        }
+    }
+
+    // Pick from preferred list first, fall back to other list if empty
+    const std::vector<size_t>* candidates =
+        prefer_laptop ? &laptop_matches : &desktop_matches;
+    if (candidates->empty())
+        candidates = prefer_laptop ? &desktop_matches : &laptop_matches;
+    if (candidates->empty())
+        return kGpuModelCount;  // no match at all
+
+    // Deterministic selection using seed
+    return (*candidates)[seed % candidates->size()];
+}
+
+// Returns the GL_VENDOR string for a given platform
+std::string BuildVendorString(const std::string& platform) {
+    if (platform.find("mac") != std::string::npos ||
+        platform.find("Mac") != std::string::npos)
+        return "Google Inc. (Apple)";
+    if (platform.find("Win") != std::string::npos ||
+        platform.find("win") != std::string::npos)
+        return "Google Inc. (NVIDIA)";
+    // Linux default
+    return "Google Inc. (NVIDIA Corporation)";
+}
+
+// Builds renderer string from a kGpuModels[] index and platform
+std::string BuildRendererString(size_t model_index,
+                                 const std::string& platform) {
+    if (model_index >= kGpuModelCount)
+        return "";
+
+    const std::string model_name(kGpuModels[model_index].model_name);
+
+    if (platform.find("mac") != std::string::npos ||
+        platform.find("Mac") != std::string::npos) {
+        // macOS: pick from Apple Silicon list via model_index mod
+        return GetMacosGpuString(model_index % kMacosGpuModelCount);
+    } else if (platform.find("Win") != std::string::npos ||
+               platform.find("win") != std::string::npos) {
+        // Windows: ANGLE D3D11 format with device ID
+        return GetWindowsGpuInfo(model_index).renderer_string;
+    } else {
+        // Linux: ANGLE OpenGL format without device ID
+        return GetLinuxGpuString(model_name);
+    }
+}
+
+}  // namespace
+
+// Public functions that will be used in WebGL code
+std::string GetGLVendorStringForFingerprint() {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+
+    // Priority 1: explicit override
+    if (cmd->HasSwitch(switches::kFingerprintGpuVendor))
+        return cmd->GetSwitchValueASCII(switches::kFingerprintGpuVendor);
+
+    if (!cmd->HasSwitch(switches::kFingerprint))
+        return "";
+
+    std::string platform = cmd->HasSwitch(switches::kFingerprintPlatform)
+        ? cmd->GetSwitchValueASCII(switches::kFingerprintPlatform)
+        : "Linux x86_64";
+
+    return BuildVendorString(platform);
+}
+
+std::string GetGLRendererStringForFingerprint() {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+
+    // Priority 1: explicit renderer override
+    if (cmd->HasSwitch(switches::kFingerprintGpuRenderer))
+        return cmd->GetSwitchValueASCII(switches::kFingerprintGpuRenderer);
+
+    if (!cmd->HasSwitch(switches::kFingerprint))
+        return "";
+
+    std::string platform = cmd->HasSwitch(switches::kFingerprintPlatform)
+        ? cmd->GetSwitchValueASCII(switches::kFingerprintPlatform)
+        : "Linux x86_64";
+
+    // Priority 2: model-based auto-derivation
+    if (cmd->HasSwitch(switches::kFingerprintGpuModel)) {
+        std::string model_input =
+            cmd->GetSwitchValueASCII(switches::kFingerprintGpuModel);
+        bool prefer_laptop = cmd->HasSwitch(switches::kFingerprintLaptop);
+
+        uint32_t seed = 0;
+        base::StringToUint(
+            cmd->GetSwitchValueASCII(switches::kFingerprint), &seed);
+
+        size_t idx = SelectGpuModelIndex(model_input, prefer_laptop, seed);
+        return BuildRendererString(idx, platform);
+    }
+
+    // Priority 3: fallback — pick from full list using seed + platform
+    uint32_t seed = 0;
+    base::StringToUint(
+        cmd->GetSwitchValueASCII(switches::kFingerprint), &seed);
+
+    if (platform.find("mac") != std::string::npos ||
+        platform.find("Mac") != std::string::npos) {
+        return GetMacosGpuString(seed % kMacosGpuModelCount);
+    }
+    return BuildRendererString(seed % kGpuModelCount, platform);
+}
+
+}  // namespace blink
