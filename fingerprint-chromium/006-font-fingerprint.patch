+// ---------------------------------------------------------------------------
+// BlutVine font fingerprint spoofing
+//
+// Goal: make font availability probes return exactly the same yes/no results
+// as stock Chrome on a typical Linux (Ubuntu/Debian) desktop install.
+//
+// Strategy:
+//   - CSS generic families and a small set of universally-present faces are
+//     always allowed through (IsAlwaysAllowedFont).
+//   - Any font name in kLinuxAllowlist is allowed through — this matches the
+//     real fontconfig set present on a stock Linux Chrome machine.
+//   - Everything else (Windows-only, macOS-only, obscure names) returns
+//     nullptr, so probes correctly report those fonts as absent.
+//   - No random hiding: the goal is deterministic identity with real Chrome,
+//     not per-seed variation (Unicode glyph path handles per-seed variation).
+// ---------------------------------------------------------------------------
+
+// Fonts that must always resolve regardless of fingerprint mode.
+// These are CSS generics, system aliases, and faces so fundamental that
+// blocking them would break page rendering.
+static bool IsAlwaysAllowedFont(const std::string& family) {
+  static const std::unordered_set<std::string> kAlways = {
+    // CSS generic families
+    "serif", "sans-serif", "monospace", "cursive", "fantasy", "math",
+    "system-ui", "-webkit-standard", "BlinkMacSystemFont",
+    // Universal web-safe faces present on every platform
+    "Arial", "Helvetica", "Helvetica Neue", "Times New Roman", "Times",
+    "Courier New", "Courier", "Verdana", "Georgia", "Trebuchet MS",
+    "Comic Sans MS", "Impact",
+    // Common Linux/Chrome UI faces
+    "Roboto", "Segoe UI", "sans", "Sans",
+  };
+  return kAlways.count(family) > 0;
+}
