 const FontPlatformData* FontCache::GetFontPlatformData(
     const FontDescription& font_description,
     const FontFaceCreationParams& creation_params,
@@ -165,6 +361,34 @@ const FontPlatformData* FontCache::GetFontPlatformData(
   }
