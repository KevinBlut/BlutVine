+// ---------------------------------------------------------------------------
+// BlutVine font fingerprint spoofing (006)
+//
+// Reads --fingerprint-platform ("windows" or "linux", default "linux").
+// Allows only the fonts that stock Chrome on that platform would report as
+// present. Everything else returns nullptr so availability probes see the
+// correct absent/present answer for the target platform.
+//
+// No random hiding — the goal is a deterministic match with real Chrome.
+// ---------------------------------------------------------------------------
+
+// Fonts that must always resolve regardless of platform spoofing.
+// These are CSS generics, universal web-safe faces, and system aliases.
+// Blocking any of these breaks page rendering.
+static bool IsAlwaysAllowedFont(const std::string& family) {
+  static const std::unordered_set<std::string> kAlways = {
+    "serif", "sans-serif", "monospace", "cursive", "fantasy", "math",
+    "system-ui", "-webkit-standard", "BlinkMacSystemFont",
+    "Arial", "Helvetica", "Helvetica Neue",
+    "Times New Roman", "Times",
+    "Courier New", "Courier",
+    "Verdana", "Georgia", "Trebuchet MS", "Comic Sans MS", "Impact",
+    "sans", "Sans", "Roboto",
+  };
+  return kAlways.count(family) > 0;
+}
