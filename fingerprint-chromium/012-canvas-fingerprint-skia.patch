 void MaskAdditiveBlitter::blitAntiH(int x, int y, SkAlpha alpha) {
     SkASSERT(x >= fMask.fBounds.fLeft - 1);
+
+    uint32_t seed = SkGetFingerprintSeed();
+    if (seed != 0 && alpha > 0 && alpha < 255) {
+        uint32_t h = seed;
+        h ^= static_cast<uint32_t>(x) * 2654435761u;
+        h ^= static_cast<uint32_t>(y) * 2246822519u;
+        h ^= h >> 16;
+        h *= 0x45d9f3bu;
+        h ^= h >> 16;
+
+        uint8_t gpu_class = SkGetFingerprintGpuClass();
+        uint32_t mag_roll = h & 0xFF;
+        uint8_t mag = 0;
+
+        if (gpu_class == kSkFingerprintGpuClassIntel) {
+            if (mag_roll >= 80) {
+                mag = 1;
+            }
+        } else if (gpu_class == kSkFingerprintGpuClassApple) {
+            if (mag_roll < 180) {
+                mag = 1;
+            } else if (mag_roll < 248) {
+                mag = 2;
+            } else {
+                mag = 3;
+            }
+        } else {
+            // NVIDIA/AMD discrete: 82% ±1, 18% ±2
+            if (mag_roll < 210) {
+                mag = 1;
+            } else {
+                mag = 2;
+            }
+        }
+
+        if (mag > 0) {
+            bool add = (h >> 8) & 1;
+            int new_alpha = add
+                ? static_cast<int>(alpha) + mag
+                : static_cast<int>(alpha) - mag;
+
+            if (new_alpha < 1)   new_alpha = 1;
+            if (new_alpha > 254) new_alpha = 254;
+
+            alpha = static_cast<SkAlpha>(new_alpha);
+        }
+
+        // Store position and our modified coverage for later RGBA correction
+        SkStoreFingerprintPixel(x, y, alpha);
+    }
+
     add_alpha(&this->getRow(y)[x], alpha);
 }
 
