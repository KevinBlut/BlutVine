+// ── Fingerprint noise helpers ─────────────────────────────────────────────
+// Derives the same base seed as offline_audio_context.cc (003 patch) using
+// identical FNV-1 hash of (--fingerprint flag + "audio"). This guarantees
+// floatFrequencyDataSum and floatTimeDomainDataSum shift consistently with
+// sampleSum — all three values move together so the knownPattern key in
+// fingerprint detectors shifts off all known entries simultaneously.
+
+static uint32_t GetAnalyserBaseSeed() {
+    const base::CommandLine* command_line =
+        base::CommandLine::ForCurrentProcess();
+    if (!command_line->HasSwitch(switches::kFingerprint))
+        return 0;
+    std::string fingerprint =
+        command_line->GetSwitchValueASCII(switches::kFingerprint);
+    if (fingerprint.empty())
+        return 0;
+    std::string seed_str = fingerprint + "audio";
+    uint32_t seed = 2166136261u;
+    for (char c : seed_str) {
+        seed ^= static_cast<uint32_t>(c);
+        seed *= 16777619u;
+    }
+    return seed;
+}
+
+// Noise for GetFloatFrequencyData output (dB float values).
+// Per-sample magnitude ±0.01 gives a total floatFrequencyDataSum shift of
+// ±10.24 over 1024 bins — reliably pushes off any known entry.
+// Uses a different XOR constant than timeDomain to avoid correlated noise
+// between the two outputs.
+static float GetFrequencyNoise(uint32_t base_seed, unsigned index) {
+    uint32_t seed = base_seed ^ static_cast<uint32_t>(index) ^ 0xF4E3D2C1u;
+    seed = seed * 1664525u + 1013904223u;
+    return ((static_cast<float>(seed) / 4294967296.0f) - 0.5f) * 0.02f;
+}
+
+// Noise for GetFloatTimeDomainData output (raw sample values, -1.0 to +1.0).
+// Per-sample magnitude ±3.79e-06 derived from the natural spread of known
+// floatTimeDomainDataSum values across real Blink hardware (total spread
+// 0.01552 over 2048 samples). Result stays within natural hardware range.
+static float GetTimeDomainNoise(uint32_t base_seed, unsigned index) {
+    uint32_t seed = base_seed ^ static_cast<uint32_t>(index) ^ 0xA1B2C3D4u;
+    seed = seed * 1664525u + 1013904223u;
+    return ((static_cast<float>(seed) / 4294967296.0f) - 0.5f) * 3.79e-06f;
+}
+
 constexpr unsigned kDefaultFFTSize = 2048;
 constexpr unsigned kInputBufferSize = RealtimeAnalyser::kMaxFFTSize * 2;
 
