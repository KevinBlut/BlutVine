index 0000000000..927483b72c
--- /dev/null
+++ b/third_party/blink/renderer/core/fingerprinting/taint_tracker.cc
@@ -0,0 +1,63 @@
+#include "third_party/blink/renderer/core/fingerprinting/taint_tracker.h"
+
+#include "base/command_line.h"
+#include "components/ungoogled/fingerprint_collector.h"
+#include "components/ungoogled/ungoogled_switches.h"
+#include "third_party/blink/renderer/core/typed_arrays/array_buffer/array_buffer_contents.h"
+#include "third_party/blink/renderer/core/typed_arrays/dom_array_buffer.h"
+#include "third_party/blink/renderer/core/typed_arrays/dom_array_buffer_view.h"
+
+namespace blink {
+
+// Global flag — fine for single-threaded collect mode.
+static bool g_fingerprinting_detected = false;
+
+bool TaintTracker::IsFingerprintingDetected() {
+  return g_fingerprinting_detected;
+}
+
+void TaintTracker::SetFingerprintingDetected(bool value) {
+  g_fingerprinting_detected = value;
+}
+
+void TaintTracker::MarkTainted(DOMArrayBuffer* buffer) {
+  if (!buffer)
+    return;
+  auto backing = buffer->Content()->BackingStore();
+  if (backing)
+    backing->SetTainted(true);
+}
+
+void TaintTracker::MarkTainted(DOMArrayBufferView* view) {
+  if (!view)
+    return;
+  MarkTainted(view->BufferBase());
+}
+
+bool TaintTracker::IsTainted(const DOMArrayBuffer* buffer) {
+  if (!buffer)
+    return false;
+  auto backing = buffer->Content()->BackingStore();
+  return backing && backing->IsTainted();
+}
+
+bool TaintTracker::IsTainted(const DOMArrayBufferView* view) {
+  if (!view)
+    return false;
+  return IsTainted(view->BufferBase());
+}
+
+void TaintTracker::OnTaintedDataExported(const String& sink_type) {
+  if (!base::CommandLine::ForCurrentProcess()->HasSwitch(
+          switches::kFingerprintCollect))
+    return;
+
+  // Mark fingerprinting as detected so subsequent API calls are logged.
+  SetFingerprintingDetected(true);
+
+  // Flush the current input log as a fingerprinting test.
+  // The site should already be set by the source API hooks.
+  fingerprint_collector::FlushTestIfNew(sink_type.Utf8(), 0.0);
+}
+
+}  // namespace blink
