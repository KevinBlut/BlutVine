+#ifndef THIRD_PARTY_BLINK_RENDERER_CORE_FINGERPRINTING_TAINT_TRACKER_H_
+#define THIRD_PARTY_BLINK_RENDERER_CORE_FINGERPRINTING_TAINT_TRACKER_H_
+
+#include "third_party/blink/renderer/core/core_export.h"
+#include "third_party/blink/renderer/platform/wtf/text/wtf_string.h"
+
+namespace blink {
+
+class DOMArrayBuffer;
+class DOMArrayBufferView;
+class ExecutionContext;
+
+// TaintTracker monitors the flow of fingerprinting data from source APIs
+// (Canvas, WebGL, Audio) to network sinks (fetch, XHR, sendBeacon).
+class CORE_EXPORT TaintTracker {
+ public:
+  // Mark data as carrying fingerprint output.
+  static void MarkTainted(DOMArrayBuffer* buffer);
+  static void MarkTainted(DOMArrayBufferView* view);
+
+  // Check if data is tainted.
+  static bool IsTainted(const DOMArrayBuffer* buffer);
+  static bool IsTainted(const DOMArrayBufferView* view);
+
+  // Called when tainted data hits a network sink.
+  // Sets the global fingerprinting-detected flag and flushes the test recipe.
+  static void OnTaintedDataExported(const String& sink_type);
+
+  // Global flag: has any fingerprinting been detected on this page?
+  static bool IsFingerprintingDetected();
+  static void SetFingerprintingDetected(bool value);
+};
+
+}  // namespace blink
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_CORE_FINGERPRINTING_TAINT_TRACKER_H_
