+
+// ---------------------------------------------------------------------------
+// Replay
+// ---------------------------------------------------------------------------
+
+struct ReplayEntry {
+    std::string bin_path;
+    int width;
+    int height;
+    std::string trigger;
+};
+
+static thread_local std::unordered_map<uint64_t, ReplayEntry> g_replay_map;
+static thread_local std::string g_replay_loaded_site;
+
+static std::string GetReplayDir() {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+
+    if (!cmd->HasSwitch(switches::kFingerprintDatabase))
+        return "";
+
+    std::string db_path = cmd->GetSwitchValueASCII(switches::kFingerprintDatabase);
+
+    std::string gpu_model = "unknown_gpu";
+    if (cmd->HasSwitch(switches::kFingerprintGpuModel))
+        gpu_model = cmd->GetSwitchValueASCII(switches::kFingerprintGpuModel);
+    std::transform(gpu_model.begin(), gpu_model.end(), gpu_model.begin(), ::tolower);
+    std::replace(gpu_model.begin(), gpu_model.end(), ' ', '_');
+
+    std::string os_version = "unknown_os";
+    if (cmd->HasSwitch(switches::kFingerprintPlatformVersion))
+        os_version = cmd->GetSwitchValueASCII(switches::kFingerprintPlatformVersion);
+    std::transform(os_version.begin(), os_version.end(), os_version.begin(), ::tolower);
+    std::replace(os_version.begin(), os_version.end(), ' ', '_');
+
+    std::string driver = "unknown_driver";
+    if (cmd->HasSwitch(switches::kFingerprintGpuDriver))
+        driver = cmd->GetSwitchValueASCII(switches::kFingerprintGpuDriver);
+    std::replace(driver.begin(), driver.end(), '.', '_');
+
+    std::string dpr = "1_0";
+    if (cmd->HasSwitch(switches::kFingerprintScreenDevicePixelRatio)) {
+        dpr = cmd->GetSwitchValueASCII(switches::kFingerprintScreenDevicePixelRatio);
+        std::replace(dpr.begin(), dpr.end(), '.', '_');
+    }
+
+    std::string site = g_current_site.empty() ? "unknown" : SanitizeForPath(g_current_site);
+    return db_path + "/" + gpu_model + "/" + os_version + "/" + driver + "/" + dpr + "/" + site + "/";
+}
+
+// Minimal JSON string field extractor — no dependencies
+static std::string JsonGetString(const std::string& json, const std::string& key) {
+    std::string needle = "\"" + key + "\":\"";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return "";
+    pos += needle.size();
+    size_t end = json.find('"', pos);
+    if (end == std::string::npos) return "";
+    return json.substr(pos, end - pos);
+}
+
+static int JsonGetInt(const std::string& json, const std::string& key) {
+    std::string needle = "\"" + key + "\":";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return 0;
+    pos += needle.size();
+    return std::stoi(json.substr(pos));
+}
+
+static void ReplayLoad() {
+    g_replay_map.clear();
+    g_replay_loaded_site = g_current_site;
+
+    std::string dir = GetReplayDir();
+    if (dir.empty()) return;
+
+    base::FilePath dir_path(dir);
+    base::FileEnumerator enumerator(dir_path, false, base::FileEnumerator::FILES,
+                                    FILE_PATH_LITERAL("*.json"));
+
+    for (base::FilePath json_path = enumerator.Next();
+         !json_path.empty();
+         json_path = enumerator.Next()) {
+
+        std::string contents;
+        if (!base::ReadFileToString(json_path, &contents)) continue;
+
+        std::string hash_str = JsonGetString(contents, "hash");
+        if (hash_str.empty()) continue;
+
+        uint64_t hash = std::stoull(hash_str, nullptr, 16);
+
+        std::string bin_path = json_path.RemoveFinalExtension().value() + ".bin";
+
+        ReplayEntry entry;
+        entry.bin_path = bin_path;
+        entry.width    = JsonGetInt(contents, "width");
+        entry.height   = JsonGetInt(contents, "height");
+        entry.trigger  = JsonGetString(contents, "trigger");
+
+        g_replay_map[hash] = std::move(entry);
+    }
+}
+
+static std::vector<uint8_t> ReplayLookup(const std::string& trigger) {
+    if (g_replay_loaded_site != g_current_site)
+        ReplayLoad();
+
+    uint64_t hash = HashInputLog();
+    g_input_log.clear();
+
+    auto it = g_replay_map.find(hash);
+    if (it == g_replay_map.end()) {
+        fprintf(stderr, "[FP-REPLAY MISS] site=%s trigger=%s\n",
+                g_current_site.c_str(), trigger.c_str());
+        return {};
+    }
+
+    const ReplayEntry& entry = it->second;
+    std::ifstream f(entry.bin_path, std::ios::binary);
+    if (!f.is_open()) {
+        fprintf(stderr, "[FP-REPLAY MISS] site=%s trigger=%s (bin missing: %s)\n",
+                g_current_site.c_str(), trigger.c_str(), entry.bin_path.c_str());
+        return {};
+    }
+
+    return std::vector<uint8_t>(
+        std::istreambuf_iterator<char>(f),
+        std::istreambuf_iterator<char>());
+}
+
+std::vector<uint8_t> ReplayCanvasOutput(const std::string& trigger) {
+    return ReplayLookup(trigger);
+}
+
+std::vector<uint8_t> ReplayWebGLOutput() {
+    return ReplayLookup("readPixels");
+}
+
 }  // namespace fingerprint_collector
