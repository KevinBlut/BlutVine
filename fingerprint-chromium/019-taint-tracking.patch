diff --git a/src/objects/js-array-buffer-inl.h b/src/objects/js-array-buffer-inl.h
index 23f4fe1e..47446814 100644
--- a/v8/src/objects/js-array-buffer-inl.h
+++ b/v8/src/objects/js-array-buffer-inl.h
@@ -19,6 +19,24 @@
 namespace v8 {
 namespace internal {
 
+bool JSArrayBuffer::is_tainted() const {
+  auto bs = GetBackingStore();
+  return bs && bs->is_tainted();
+}
+
+void JSArrayBuffer::set_tainted(bool tainted) {
+  auto bs = GetBackingStore();
+  if (bs) bs->set_tainted(tainted);
+}
+
+void JSArrayBuffer::propagate_taint_from(Tagged<JSArrayBuffer> other) {
+  auto my_bs = GetBackingStore();
+  auto other_bs = other->GetBackingStore();
+  if (my_bs && other_bs) {
+    my_bs->propagate_taint_from(other_bs.get());
+  }
+}
+
