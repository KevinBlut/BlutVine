   return accessor->CopyElements(isolate, source, target, length, offset);
 }
 
+RUNTIME_FUNCTION(Runtime_TypedArrayPropagateTaint) {
+  HandleScope scope(isolate);
+  DCHECK_EQ(2, args.length());
+  Handle<JSTypedArray> target = args.at<JSTypedArray>(0);
+  Handle<JSTypedArray> source = args.at<JSTypedArray>(1);
+
+  if (source->is_tainted()) {
+    target->set_tainted(true);
+  }
+  return ReadOnlyRoots(isolate).undefined_value();
+}
